<h1>Edit Message</h1>

<%= form_with(model: [@task, @message], local: true) do |f| %>
  <div class="mb-4">
    <%= f.label :content, "Content", class: "block text-gray-700 font-bold mb-2" %>
    <%= f.rich_text_area :content,
        class: "w-full min-h-[400px] rounded border border-gray-300 p-2 focus:ring-2 focus:ring-blue-500",
        required: true %>
  </div>

  <div class="flex space-x-2">
    <%= f.submit "Update Message",
        class: "bg-blue-500 hover:bg-blue-600 text-white font-bold py-2 px-4 rounded" %>
    <%= link_to "Cancel",
        task_messages_path(@task),
        class: "bg-gray-300 hover:bg-gray-400 text-gray-800 font-bold py-2 px-4 rounded" %>
  </div>
<% end %>
