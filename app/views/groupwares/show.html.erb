<% provide(:title, "Sub products for CS products: #{@software.name}") %>

<% if flash[:notice] %>
  <div class="bg-[#1a237e] border border-[#4caf50] text-white px-4 py-3 rounded mb-4 shadow-md">
    <p><%= flash[:notice] %></p>
  </div>
<% elsif flash[:alert] %>
  <div class="bg-red-600 border border-red-400 text-white px-4 py-3 rounded mb-4 shadow-md">
    <p><%= flash[:alert] %></p>
  </div>
<% end %>

<div class="flex gap-2">
Sub Product: <%= @groupware.name %>



  <% if current_user.has_role? :admin  %>
    <div class="flex gap-1">
      <%= button_to 'Back', software_path(@software.id), method: :get, class: 'bg-[#3F8CFF] hover:bg-[#3A81EB] p-2 rounded font-bold rounded-lg text-slate-100'  %>

      <%= button_to 'Add Module +', new_software_groupware_script_path(@software, @groupware), method: :get, class: 'bg-[#3F8CFF] hover:bg-[#3A81EB] p-2 rounded font-bold rounded-lg text-slate-100'  %>
    </div>
  <% end %>
</div>

<!-- add scripts -->

<%= render 'scripts/script' %>