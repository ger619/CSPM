<div class="overflow-x-auto shadow-md sm:rounded-lg h-full w-full">
  <table class="w-full text-sm text-left rtl:text-right">
    <thead class="text-xs text-gray-700 uppercase bg-gray-50 dark:bg-gray-700 dark:text-gray-400">
      <tr>
        <th scope="col" class="px-6 py-3 w-1/4"> 
          Name of the software
        </th>
        <th scope="col" class="px-6 py-3 w-1/2"> 
          Description of the software
        </th>
        <% if can?(:edit, @software) || can?(:delete, @software) %>
          <th scope="col" class="px-6 py-3">
            ACTIONS
          </th>
        <% end %>
      </tr>
    </thead>
    <tbody>
      <% @software.each do |software| %>
        <tr class="bg-white border-b dark:bg-gray-800 dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-600">
          <td class="px-6 py-4 font-medium whitespace-nowrap w-1/4"> 
            <%= link_to software.name, software_path(software.id) %>
          </td>
          <td class="px-6 py-4 w-1/2">  
            <div class="truncate">
              <%= software.description %>
            </div>
          </td>

          <% if can?(:edit, software) || can?(:delete, software) %>
            <!-- Actions li -->
            <td class="px-6 py-4 whitespace-nowrap font-medium text-right" data-controller="dropdown" data-dropdown-ticket-id-value="<%= software.id %>"> 
              <div class="relative flex justify-start"> 
                <%= render partial: 'software/action_dropdown', locals: { software: software } %>
              </div>
            </td>
          <% end %>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>