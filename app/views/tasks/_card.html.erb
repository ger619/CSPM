<%= link_to product_task_path(task.product, task) do %>
<% end %>

<div class="product-task-top p-2 w-full min-w-2xl bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 overflow-hidden" style="max-width: 42rem;">
  <div class="flex items-center justify-between p-4 border-b border-gray-200 dark:border-gray-700">
    <h3 class="text-lg font-semibold text-gray-900 dark:text-white"><%= @product.client.name %></h3>
    <%= render partial: "tasks/action_dropdown", locals: { product: @product, task: task } %>
  </div>

  <div class="p-4">
    <div class="mb-3">
      <h2 class="text-xl font-bold text-gray-900 dark:text-white"><%= task.name %></h2>
    </div>

    <div class="flex items-center justify-between">
      <div class="product-task-middle-bottom-left">
        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-200">
          High
        </span>
      </div>
      <div class="product-task-middle-bottom-right flex items-center space-x-1 text-sm text-gray-500 dark:text-gray-400">
        <% due_date = task.end_date %>
        <% days_left = (due_date - Date.today).to_i %>
        <% due_date_class = case
          when days_left > 14
            'bg-green-500 text-white'
          when days_left <= 7 && days_left > 3
            'bg-yellow-500 text-white'
          when days_left <= 3 && days_left >= 0
            'bg-orange-500 text-white'
          else
            'bg-red-500 text-white'
        end %>

        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" />
        </svg>
        <span><%= task.end_date.strftime("%b %d, %Y") %></span>
      </div>
    </div>
  </div>

  <div class="grid grid-cols-3 items-center gap-4">
    <!-- Users Column -->
    <div class="flex items-center space-x-2 overflow-x-auto">
      <% task.users.each do |user| %>
        <% if user.profile_picture.attached? %>
          <%= image_tag user.profile_picture, class: 'object-cover h-10 w-10 rounded-full flex-shrink-0' %>
        <% elsif user.name_initials.present? %>
          <p class="w-10 h-10 flex items-center justify-center rounded-full bg-gray-300 text-gray-800 capitalize flex-shrink-0">
            <%= user.name_initials %>
          </p>
        <% else %>
          <%= image_tag 'default.png', class: 'w-10 h-10 rounded-full flex-shrink-0' %>
        <% end %>
      <% end %>
    </div>

    <!-- Messages Column -->
    <div class="flex items-center justify-center space-x-2">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
      </svg>
      <p class="text-sm"><%= task.messages.count %></p>
    </div>

    <!-- Attachments Column -->
    <div class="flex items-center justify-end space-x-2">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
        <path stroke-linecap="round" stroke-linejoin="round" d="m18.375 12.739-7.693 7.693a4.5 4.5 0 0 1-6.364-6.364l10.94-10.94A3 3 0 1 1 19.5 7.372L8.552 18.32m.009-.01-.01.01m5.699-9.941-7.81 7.81a1.5 1.5 0 0 0 2.112 2.13" />
      </svg>
      <% attachment_count = [task.image, task.file].count(&:attached?) %>
      <p class="text-sm"><%= attachment_count > 0 ? attachment_count : "" %></p>
    </div>
  </div>
</div>