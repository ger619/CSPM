<div class="bg-white dark:bg-gray-800 shadow-md rounded-lg border" style="cursor: pointer; ">
  <div class="flex justify-between mb-2 bg-gray-200 dark:bg-gray-700 p-4 rounded-t-lg">
    <div class="flex items-center gap-4">
      <h3 class="text-lg font-semibold"><%= @product.client.name %></h3>
    </div>
    <div>
      <%= render partial: "tasks/action_dropdown", locals: { product: @product, task: task } %>
    </div>
  </div>

  <div class="p-4">
    <div class="mb-4">
      <h2 class="text-xs font-bold">
        <% if task.prerequisite_task.present? %>
          <%= task.prerequisite_task.name %>
        <% else %>
          No prerequisite
        <% end %>
      </h2>

    </div>
    <div class="mb-4">
      <h2 class="text-xs font-bold"><%= task.name %></h2>
    </div>

    <div class="flex items-center justify-between mb-4">
      <div class="text-xs">
        <%= render partial: 'tasks/priority', locals: { task: task } %>
      </div>
      <div class="flex items-center space-x-2 text-sm text-gray-500 dark:text-gray-400">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" />
        </svg>
        <span><%= task.end_date.strftime("%b %d, %Y") %></span>
      </div>
    </div>

    <div class="p-2">
      <hr class="border-gray-200 dark:border-gray-700">
    </div>

    <div class="grid grid-cols-2 items-center gap-4 pt-2">
      <div class="flex items-center space-x-2 overflow-x-auto">
        <% task.users.each do |user| %>
          <% if user.profile_picture.attached? %>
            <%= image_tag user.profile_picture, class: 'object-cover h-10 w-10 rounded-full flex-shrink-0' %>
          <% elsif user.name_initials.present? %>
            <p class="w-10 h-10 flex items-center justify-center rounded-full bg-gray-300 text-gray-800 capitalize flex-shrink-0">
              <%= user.name_initials %>
            </p>
          <% else %>
            <%= image_tag 'default.png', class: 'w-10 h-10 rounded-full flex-shrink-0' %>
          <% end %>
        <% end %>
      </div>

      <div class="flex items-center justify-center space-x-2">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
          <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 8.25h9m-9 3H12m-9.75 1.51c0 1.6 1.123 2.994 2.707 3.227 1.129.166 2.27.293 3.423.379.35.026.67.21.865.501L12 21l2.755-4.133a1.14 1.14 0 0 1 .865-.501 48.172 48.172 0 0 0 3.423-.379c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0 0 12 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018Z" />
        </svg>
        <p class="text-sm"><%= task.messages.count %></p>
      </div>
    </div>
  </div>
</div>