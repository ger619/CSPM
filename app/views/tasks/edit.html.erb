
  <%= form_with(model: [@product, @task], method: :patch) do |f| %>
    <div class="gap-2 m-2">
      <%= link_to product_path(@product.id), method: :get, class: 'mb-4 h-12 bg-[#3F8CFF] hover:bg-[#3A81EB] p-3 rounded font-bold rounded-lg text-slate-100' do %>
        &#8656; Back
      <% end %>
      <div class="grid grid-cols-2 gap-2 mt-4">
        <div class="relative z-0 w-full mb-6 group">
          <%= f.label :name, :name, class: "capitalize block mb-1 text-sm font-medium" %><br />
          <%= f.text_field :name, class: "border border-gray-300 rounded-lg focus:ring-primary-600 focus:border-primary-600 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:focus:ring-blue-500 dark:focus:border-blue-500", placeholder: '', required: true %>
        </div>
        
        <div class="relative z-0 w-full mb-6 group">
          <%= f.label :priority, ('Priority *'), class: "capitalize block mb-1 text-sm font-medium text-gray-900 dark:text-white"  %><br />
          <%= f.select :priority, ['SEVERITY 1','SEVERITY 2','SEVERITY 3','SEVERITY 4'], {}, class: "border border-gray-300 rounded-lg focus:ring-primary-600 focus:border-primary-600 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:focus:ring-blue-500 dark:focus:border-blue-500", placeholder: 'Select The Issue' %>
        </div>
      </div>

      <div class="grid grid-cols-2 gap-2 mt-4"> 
        <div class="relative z-0 w-full mb-6 group">
          <%= f.label :image, ('Task Image'), class: "capitalize block mb-1 text-sm font-medium" %><br />
          <%= f.file_field :image, class: "border border-gray-300 rounded-lg focus:ring-primary-600 focus:border-primary-600 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:focus:ring-blue-500 dark:focus:border-blue-500", placeholder: '' %>
        </div>
        <div class="relative z-0 w-full mb-6 group">
          <%= f.label :file, ('Task File'), class: "capitalize block mb-1 text-sm font-medium" %><br />
          <%= f.file_field :file, class: "border border-gray-300 rounded-lg focus:ring-primary-600 focus:border-primary-600 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:focus:ring-blue-500 dark:focus:border-blue-500", placeholder: '' %>
        </div>
      </div>
      <% if flash[:alert] %>
        <div class="alert alert-danger">
          <%= flash[:alert] %>
        </div>
      <% end %>
      <div class="grid grid-cols-2 gap-2">
        <div class="relative z-0 w-full mb-6 group">
          <%= f.label :start_date, 'Start Date', class: "capitalize block mb-1 text-sm font-medium"  %><br />
          <%= f.date_field :start_date, class: "border border-gray-300 rounded-lg focus:ring-primary-600 focus:border-primary-600 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:focus:ring-blue-500 dark:focus:border-blue-500", placeholder: '', required: true %>
        </div>
        <div class="relative z-0 w-full mb-6 group">
          <%= f.label :end_date, 'End Date', class: "capitalize block mb-1 text-sm font-medium text-gray-900 dark:text-white"  %><br />
          <%= f.date_field :end_date, class: "border border-gray-300 rounded-lg focus:ring-primary-600 focus:border-primary-600 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:focus:ring-blue-500 dark:focus:border-blue-500", placeholder: '', required: true %>
        </div>
      </div>

      <div class="w-full">
        <div class="relative z-0 w-full mb-6 group">
          <%= f.label :description, :description, class: "capitalize block mb-1 text-sm font-medium" %><br />
          <%= f.rich_text_area :description, class: "border border-gray-300 rounded-lg focus:ring-primary-600 focus:border-primary-600 block w-full min-h-64 p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:focus:ring-blue-500 dark:focus:border-blue-500", placeholder: '', required: true %>
        </div>
      </div>

      <%= f.submit 'Edit Task', class: 'mb-4 h-12 bg-[#3F8CFF] hover:bg-[#3A81EB] p-3 rounded font-bold rounded-lg text-slate-100' %>
    </div>

  <% end %>