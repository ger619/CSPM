<%= turbo_frame_tag "modal" do %>
  <div class="fixed inset-0 bg-black bg-opacity-50 backdrop-blur-sm flex justify-center items-center z-50">
    <div class="bg-white dark:bg-gray-800 p-6 rounded-lg shadow-xl w-full max-w-5xl relative max-h-[90vh] overflow-y-auto">
      <!-- Close Button -->
      <%= link_to "X", product_path(@product), data: { turbo_frame: "_top" }, class: "absolute top-3 right-3 text-xl font-bold text-gray-500 hover:text-gray-700 dark:text-gray-300 dark:hover:text-gray-100" %>

      <!-- Header -->
      <h2 class="text-2xl font-semibold text-gray-800 dark:text-gray-100 mb-6">Add New Task</h2>

      <%= form_with(model: [product, product.tasks.build], data: { turbo: false }) do |f| %>
        <div class="space-y-6">
          <!-- Error Messages -->
          <% if flash[:alert] %>
            <div id="error_explanation" class="bg-red-50 dark:bg-red-900/10 p-4 rounded-lg">
              <h2 class="text-red-600 dark:text-red-400 font-medium mb-2">Error:</h2>
              <ul class="list-disc list-inside text-red-500 dark:text-red-400">
                <li><%= flash[:alert] %></li>
              </ul>
            </div>
          <% end %>


          <!-- Prerequisite -->
          <div class="bg-gray-50 dark:bg-gray-700 p-4 rounded-lg">
            <div class="relative z-0 w-full mb-6 group">
              <%= f.label :prerequisite, ('Prerequisite'), class: "capitalize block mb-2 text-sm font-medium text-gray-900 dark:text-white" %>
              <%= f.collection_select :tasks_id, @prerequisite_tasks, :id, :name,
                                      { prompt: "Select Task" },
                                      class: "border border-gray-300 rounded-lg focus:ring-primary-600 focus:border-primary-600 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white dark:focus:ring-blue-500 dark:focus:border-blue-500"
              %>


            </div>
          </div>

          <!-- Name -->
          <div class="bg-gray-50 dark:bg-gray-700 p-4 rounded-lg">
            <div class="relative z-0 w-full mb-6 group">
              <%= f.label :name, ('Name*'), class: "capitalize block mb-2 text-sm font-medium text-gray-900 dark:text-white" %>
              <%= f.text_field :name, class: "border border-gray-300 rounded-lg focus:ring-primary-600 focus:border-primary-600 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white dark:focus:ring-blue-500 dark:focus:border-blue-500", placeholder: '', required: true %>
            </div>
          </div>

          <!-- Priority Field -->
          <div class="bg-gray-50 dark:bg-gray-700 p-4 rounded-lg">
            <%= f.label :priority, ('Priority *'), class: "capitalize block mb-1 text-sm font-medium text-gray-900 dark:text-white"  %><br />
            <%= f.select :priority, options_for_select(['SEVERITY 1','SEVERITY 2','SEVERITY 3','SEVERITY 4']), {}, class: "border border-gray-300 rounded-lg focus:ring-primary-600 focus:border-primary-600 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:focus:ring-blue-500 dark:focus:border-blue-500", placeholder: 'Select The Issue', required: true %>
            <% if @task.errors[:priority].any? %>
              <div class="text-red-500 text-sm"><%= @task.errors[:priority].join(", ") %></div>
            <% end %>
          </div>

          <!-- Image and File Uploads -->
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <!-- Task Image -->
            <div class="bg-gray-50 dark:bg-gray-700 p-4 rounded-lg">
              <div class="relative z-0 w-full mb-6 group">
                <%= f.label :image, ('Task Image (Only Images)'), class: "capitalize block mb-2 text-sm font-medium text-gray-900 dark:text-white" %>
                <%= f.file_field :image, accept: 'image/*', class: "border border-gray-300 rounded-lg focus:ring-primary-600 focus:border-primary-600 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white dark:focus:ring-blue-500 dark:focus:border-blue-500" %>
              </div>
            </div>

            <!-- Task File -->
            <div class="bg-gray-50 dark:bg-gray-700 p-4 rounded-lg">
              <div class="relative z-0 w-full mb-6 group">
                <%= f.label :file, ('Task File (Only files)'), class: "capitalize block mb-2 text-sm font-medium text-gray-900 dark:text-white" %>
                <%= f.file_field :file, accept: '*/*', class: "border border-gray-300 rounded-lg focus:ring-primary-600 focus:border-primary-600 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white dark:focus:ring-blue-500 dark:focus:border-blue-500" %>
              </div>
            </div>
          </div>

          <!-- Dates -->
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <!-- Start Date -->
            <div class="bg-gray-50 dark:bg-gray-700 p-4 rounded-lg">
              <div class="relative z-0 w-full mb-6 group">
                <%= f.label :start_date, 'Start Date*', class: "capitalize block mb-2 text-sm font-medium text-gray-900 dark:text-white" %>
                <div class="relative">
                  <div class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none">
                    <svg class="w-4 h-4 text-gray-500 dark:text-gray-400" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 20 20">
                      <path d="M20 4a2 2 0 0 0-2-2h-2V1a1 1 0 0 0-2 0v1h-3V1a1 1 0 0 0-2 0v1H6V1a1 1 0 0 0-2 0v1H2a2 2 0 0 0-2 2v2h20V4ZM0 18a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V8H0v10Zm5-8h10a1 1 0 0 1 0 2H5a1 1 0 0 1 0-2Z"/>
                    </svg>
                  </div>
                  <%= f.date_field :start_date, class: "border border-gray-300 rounded-lg focus:ring-primary-600 focus:border-primary-600 block w-full pl-10 p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white dark:focus:ring-blue-500 dark:focus:border-blue-500", required: true %>
                </div>
              </div>
            </div>

            <!-- End Date -->
            <div class="bg-gray-50 dark:bg-gray-700 p-4 rounded-lg">
              <div class="relative z-0 w-full mb-6 group">
                <%= f.label :end_date, 'End Date*', class: "capitalize block mb-2 text-sm font-medium text-gray-900 dark:text-white" %>
                <div class="relative">
                  <div class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none">
                    <svg class="w-4 h-4 text-gray-500 dark:text-gray-400" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 20 20">
                      <path d="M20 4a2 2 0 0 0-2-2h-2V1a1 1 0 0 0-2 0v1h-3V1a1 1 0 0 0-2 0v1H6V1a1 1 0 0 0-2 0v1H2a2 2 0 0 0-2 2v2h20V4ZM0 18a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V8H0v10Zm5-8h10a1 1 0 0 1 0 2H5a1 1 0 0 1 0-2Z"/>
                    </svg>
                  </div>
                  <%= f.date_field :end_date, class: "border border-gray-300 rounded-lg focus:ring-primary-600 focus:border-primary-600 block w-full pl-10 p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white dark:focus:ring-blue-500 dark:focus:border-blue-500", required: true %>
                </div>
              </div>
            </div>
          </div>

          <!-- Description -->
          <div class="bg-gray-50 dark:bg-gray-700 p-4 rounded-lg">
            <div class="relative z-0 w-full group">
              <%= f.label :description, 'Description*', class: "capitalize block mb-2 text-sm font-medium text-gray-900 dark:text-white" %>
              <%= f.rich_text_area :description,
                class: "min-h-[200px] border border-gray-300 rounded-lg dark:bg-gray-700 dark:border-gray-600 dark:text-white",
                required: true %>
            </div>
          </div>

          <!-- Submit Button -->
          <div class="flex justify-end">
            <%= f.submit 'Add Task', class: "px-4 py-2 text-sm font-medium text-white bg-blue-700 rounded-lg hover:bg-blue-800 focus:ring-4 focus:ring-blue-300 dark:bg-blue-600 dark:hover:bg-blue-700 focus:outline-none dark:focus:ring-blue-800" %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
<% end %>