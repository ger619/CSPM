<% allowed_roles = ["external", :admin, :agent, :observer, "project manager"] %>
<div class="flex flex-col h-full" data-controller="messages">
  <!-- Messages Container -->
  <div class="flex-1 overflow-y-auto">
    <% if @ticket_items.present? %>
      <ol class="relative space-y-6 messages-list" id="messages-list">
        <% @ticket_items.each do |item| %>
          <% if item.is_a?(Comment) || (item.is_a?(Issue) && (allowed_roles.include?(item.message_type) || allowed_roles.any? { |role| current_user.has_role?(role) })) %>
            <%= render 'issues/message', item: item %>
          <% end %>
        <% end %>
      </ol>
    <% else %>
      <div class="flex flex-col items-center justify-center h-64 text-gray-400 dark:text-gray-500">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z" />
        </svg>
        <p>No messages yet</p>
      </div>
    <% end %>
  </div>

  <% if @total_pages.present? && @total_pages > 1 %>
    <div class="mt-6 flex items-center justify-between border-t border-gray-200 dark:border-gray-700 pt-4">
      <% if @page > 1 %>
        <%= link_to 'Previous', project_ticket_path(@project, @ticket, ticket_items_page: @page - 1), 
            class: 'px-4 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white' %>
      <% end %>
      
      <span class="text-sm text-gray-500 dark:text-gray-400">
        Page <%= @page %> of <%= @total_pages %>
      </span>
      
      <% if @page < @total_pages %>
        <%= link_to 'Next', project_ticket_path(@project, @ticket, ticket_items_page: @page + 1), 
            class: 'px-4 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white' %>
      <% end %>
    </div>
  <% end %>
</div>
