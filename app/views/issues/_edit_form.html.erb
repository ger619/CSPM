<%= form_with(model: [project, ticket, issue], 
              html: { multipart: true, 
                     data: { controller: 'messages', 
                            action: 'turbo:submit-end->messages#handleSubmit' } }, 
              remote: true) do |f| %>
  <div class="space-y-4">
    <h3 class="text-lg font-bold text-gray-900 dark:text-white">Edit Message *</h3>

    <!-- Message Content -->
    <div data-controller="text-limit" data-text-limit-limit-value="3000">
      <p class="text-xs text-gray-500 dark:text-gray-400 mb-1" id="char-count">0/3000</p>
      
      <%= f.rich_text_area :content, id: "content",
                         data: { text_limit_target: "content", is_admin: current_user.has_role?(:admin) || current_user.has_role?('project manager') || current_user.has_role?('agent')},
                         class: "trix-content w-full border border-gray-300 dark:border-gray-600 rounded-lg p-3 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 dark:bg-gray-700 dark:text-white min-h-[200px] #{'border-red-500' if issue.errors[:content].any?}" %>

      <% if issue.errors[:content].any? %>
        <p class="mt-1 text-sm text-red-600 dark:text-red-400" id="content-error">
          <%= issue.errors[:content].join(', ') %>
        </p>
      <% end %>
    </div>

    <% unless current_user.has_role?(:client) %>
      <!-- User Selection -->
      <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Notify Users</label>
        <div class="relative">
          <input type="text" id="searchUser-<%= issue.id %>" 
                 class="w-full border border-gray-300 dark:border-gray-600 rounded-lg p-2.5 text-sm dark:bg-gray-700 dark:text-white"
                 placeholder="Search User..." 
                 onclick="showDropdown('<%= issue.id %>')" 
                 onkeyup="filterUserDropdown('<%= issue.id %>')" 
                 autocomplete="off">
          
          <div id="selectedUsers-<%= issue.id %>" class="flex flex-wrap gap-2 mt-2">
            <% if issue.respond_to?(:users) %>
              <% issue.users.each do |user| %>
                <div class="bg-blue-100 text-blue-800 px-2 py-1 rounded-md flex items-center gap-2 text-sm">
                  <%= user.name %>
                  <span onclick="removeUser('<%= issue.id %>', '<%= user.id %>', this)" class="cursor-pointer text-red-500">×</span>
                  <input type="hidden" name="team[user_ids][]" value="<%= user.id %>" class="user-input-<%= user.id %>">
                </div>
              <% end %>
            <% elsif issue.respond_to?(:user) && issue.user.present? %>
              <div class="bg-blue-100 text-blue-800 px-2 py-1 rounded-md flex items-center gap-2 text-sm">
                <%= issue.user.name %>
                <span onclick="removeUser('<%= issue.id %>', '<%= issue.user.id %>', this)" class="cursor-pointer text-red-500">×</span>
                <input type="hidden" name="team[user_ids][]" value="<%= issue.user.id %>" class="user-input-<%= issue.user.id %>">
              </div>
            <% end %>
          </div>
          <div id="hiddenUserInputs-<%= issue.id %>"></div>
          
          <div id="userDropdown-<%= issue.id %>" class="hidden absolute z-10 w-full mt-1 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 rounded-lg shadow-lg max-h-60 overflow-y-auto">
            <div class="p-2">
              <div class="flex justify-end">
                <button type="button" onclick="hideDropdown('<%= issue.id %>')" class="text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-300">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5">
                    <path fill-rule="evenodd" d="M5.47 5.47a.75.75 0 011.06 0L12 10.94l5.47-5.47a.75.75 0 111.06 1.06L13.06 12l5.47 5.47a.75.75 0 11-1.06 1.06L12 13.06l-5.47 5.47a.75.75 0 01-1.06-1.06L10.94 12 5.47 6.53a.75.75 0 010-1.06z" clip-rule="evenodd" />
                  </svg>
                </button>
              </div>

              <div id="externalUsers-<%= issue.id %>" class="user-list">
                <% project.users.distinct.order(:first_name).each do |user| %>
                  <% if (issue.respond_to?(:users) && !issue.users.include?(user)) || (issue.respond_to?(:user) && issue.user != user) %>
                    <div class="px-3 py-2 hover:bg-gray-100 dark:hover:bg-gray-700 cursor-pointer"
                         data-user-id="<%= user.id %>"
                         onclick="selectUser('<%= issue.id %>', this)">
                      <%= user.name %>
                    </div>
                  <% end %>
                <% end %>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Message Type -->
      <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Message Visibility</label>
        <%= f.select :message_type,
                     options_for_select([["Reply To Customer", "external"], ["Add Internal Note", "internal"]],
                                        selected: (issue.respond_to?(:message_type) ? issue.message_type : "external")),
                     {},
                     class: "w-full border border-gray-300 dark:border-gray-600 rounded-lg p-2.5 text-sm dark:bg-gray-700 dark:text-white" %>      </div>
    <% end %>

    <!-- Form Actions -->
    <div class="flex justify-end gap-3 pt-2">
      <button type="button" 
              class="px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 dark:bg-gray-700 dark:text-gray-300 dark:border-gray-600 dark:hover:bg-gray-600"
              data-action="click->messages#showEditForm"
              data-message-id="<%= issue.id %>">
        Cancel
      </button>
      <%= f.submit "Update Message", 
          class: "px-4 py-2 text-sm font-medium text-white bg-blue-600 rounded-lg hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500" %>
    </div>
  </div>
<% end %>

<script>
  // Make sure these functions are unique per form
  function showDropdown(formId) {
    document.getElementById(`userDropdown-${formId}`).classList.remove("hidden");
  }

  function hideDropdown(formId) {
    document.getElementById(`userDropdown-${formId}`).classList.add("hidden");
  }

  function filterUserDropdown(formId) {
    let input = document.getElementById(`searchUser-${formId}`).value.toLowerCase();
    let items = document.querySelectorAll(`#userDropdown-${formId} .user-list > div`);

    items.forEach(item => {
      let text = item.textContent.toLowerCase();
      item.style.display = text.includes(input) ? "block" : "none";
    });
  }

  function selectUser(formId, element) {
    let userId = element.getAttribute("data-user-id");
    let userName = element.textContent;

    // Update Selected UI
    let tag = document.createElement("div");
    tag.className = "bg-blue-100 text-blue-800 px-2 py-1 rounded-md flex items-center gap-2 text-sm";
    tag.innerHTML = `${userName} <span onclick="removeUser('${formId}', '${userId}', this)" class="cursor-pointer text-red-500">×</span>`;
    document.getElementById(`selectedUsers-${formId}`).appendChild(tag);

    // Add hidden input
    let input = document.createElement("input");
    input.type = "hidden";
    input.name = "team[user_ids][]";
    input.value = userId;
    input.classList.add(`user-input-${userId}`);
    document.getElementById(`hiddenUserInputs-${formId}`).appendChild(input);

    // Remove from dropdown
    element.remove();
    hideDropdown(formId);
  }

  function removeUser(formId, userId, element) {
    // Remove from UI
    element.parentElement.remove();

    // Remove hidden input
    let input = document.querySelector(`#hiddenUserInputs-${formId} .user-input-${userId}`);
    if (input) input.remove();

    // Add back to dropdown
    let dropdown = document.getElementById(`userDropdown-${formId}`);
    let item = document.createElement("div");
    item.className = "px-3 py-2 hover:bg-gray-100 dark:hover:bg-gray-700 cursor-pointer";
    item.setAttribute("data-user-id", userId);
    item.setAttribute("onclick", `selectUser('${formId}', this)`);
    item.textContent = element.parentElement.textContent.replace('×', '').trim();
    document.getElementById(`externalUsers-${formId}`).appendChild(item);
  }
</script>