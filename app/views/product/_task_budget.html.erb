<!--to show the tasks budget and end date -->
<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 mb-6">
    <div class="bg-white dark:bg-gray-800 p-2">
      <h3 class="text-sm font-light mb-2">Tasks</h3>
      <p class="text-md font-semibold">10/20</p>
    </div>
    <div class="bg-white dark:bg-gray-800 p-2">
      <h3 class="text-sm font-light mb-2">Budget</h3>
      <p class="text-md font-semibold">Kshs. <%= product&.budget || 0 %></p>
    </div>
    <div class="bg-white dark:bg-gray-800 p-4">
      <h3 class="text-sm font-light mb-2">Due On</h3>
      <p class="text-md font-semibold"><%= product.end_date.strftime("%d-%b-%y") if product.end_date %></p>
    </div>
</div>