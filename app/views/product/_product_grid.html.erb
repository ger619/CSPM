<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
  <% @product.each do |product| %>
    <div class="bg-white dark:bg-gray-800 shadow-md rounded-lg" style="cursor:pointer;" onclick="window.location='<%= product_path(product.id) %>'">
      <div>
        <div class="flex justify-between mb-4 bg-gray-200 dark:bg-gray-700 p-4 rounded-t-lg">
          <div class="flex items-center gap-4">
          <% if product.image.present? %>
            <%= image_tag(product.image, class: 'w-8 h-8 rounded-full') %>
          <% else %>
            <%= image_tag 'default.png', class: 'w-8 h-8 rounded-full' %>
          <% end %>
            <p class="text-sm font-semibold uppercase"><%= product.client.present? ? product.client.name : 'No Client Assigned' %></p>
          </div>
          <div class="rounded-full border p-2 border-white">
            <p class="text-sm font-semibold"><%= product.name %></p>
          </div>
        </div>
        <div class="p-4">
          <p class="text-sm text-gray-500">Assigned to: <%= product.user.name %></p>
          <p class="text-sm text-gray-500">Client: <%= product.client.present? ? product.client.name : 'No Client Assigned' %></p>
        </div>
      </div>
      <div class="p-2">
        <hr>
      </div>


      <div class="p-4">
        <!-- All users assigned to the product show first 5 only-->
        <div class="flex flex-wrap gap-2 items-center">
          <% if product.users.any? %>
            <% product.users.first(5).each do |user| %>
              <% if user.profile_picture.attached? %>
                <%= image_tag user.profile_picture, class: 'w-10 h-10 rounded-md' %>
              <% elsif user.name_initials.present? %>
              <span class="w-10 h-10 inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-200">
                  <%= user.name_initials %>
                </span>
              <% else %>
                <%= image_tag 'default.png', class: 'w-10 h-10 rounded-full' %>
              <% end %>
            <% end %>
          <% else %>
            <p class="text-gray-600 dark:text-gray-300">No users assigned to this product yet.</p>
          <% end %>
        </div>
      </div>



      </div>
  <% end %>
</div>