<%= turbo_frame_tag "modal" do %>
  <div class="fixed inset-0 bg-black bg-opacity-50 backdrop-blur-sm flex justify-center items-center z-50">
    <div class="bg-white dark:bg-gray-800 p-6 rounded-lg shadow-xl w-full max-w-5xl relative max-h-[90vh] overflow-y-auto">
      <!-- Close Button -->
      <%= link_to "X", product_index_path, data: {
        turbo_frame: "_top"
      }, class: "absolute top-3 right-3 text-xl font-bold text-gray-500 hover:text-gray-700 dark:text-gray-300 dark:hover:text-gray-100" %>


      <!-- Header -->
      <h2 class="text-2xl font-semibold text-gray-800 dark:text-gray-100 mb-6">Add new Project</h2>

      <%= form_with model: @product, url: product_index_url, method: :post, data: { turbo: false }, local: true, html: { multipart: true } do |f| %>
        <div class="space-y-6">
          <!-- Error Messages -->
          <% if @product.errors.any? %>
            <div id="error_explanation" class="bg-red-50 dark:bg-red-900/10 p-4 rounded-lg">
              <h2 class="text-red-600 dark:text-red-400 font-medium mb-2"><%= pluralize(@product.errors.count, "error") %> prohibited this project from being saved:</h2>
              <ul class="list-disc list-inside text-red-500 dark:text-red-400">
                <% @product.errors.full_messages.each do |message| %>
                  <li><%= message %></li>
                <% end %>
              </ul>
            </div>
          <% end %>


          <!-- Client Name -->
          <div class="bg-gray-50 dark:bg-gray-700 p-4 rounded-lg">
            <div class="relative z-0 w-full mb-6 group">
              <%= f.label :software, ('Client*'), class: "capitalize block mb-2 text-sm font-medium text-gray-900 dark:text-white" %>
              <%= f.collection_select :client_id, Client.all, :id, :name, { prompt: "Select Client" }, class: "border border-gray-300 rounded-lg focus:ring-primary-600 focus:border-primary-600 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white dark:focus:ring-blue-500 dark:focus:border-blue-500", required: true %>
            </div>
          </div>

          <!-- Project Category and Sub Category -->
          <div class="space-y-4">
            <!-- Project Category -->
            <div class="bg-gray-50 dark:bg-gray-700 p-4 rounded-lg">
              <div class="relative z-0 w-full mb-6 group">
                <%= f.label :categories, ('Project Category*'), class: "capitalize block mb-2 text-sm font-medium text-gray-900 dark:text-white" %>
                <%= f.collection_select :software_ids, Software.all, :id, :name,
                                      { prompt: "Select Product", include_hidden: false },
                                      class: "border border-gray-300 rounded-lg focus:ring-primary-600 focus:border-primary-600 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white dark:focus:ring-blue-500 dark:focus:border-blue-500",
                                      data: { action: "change->form#updateGroupwareOptions" },
                                      required: true %>
              </div>
            </div>

            <!-- Sub Category -->
            <div class="bg-gray-50 dark:bg-gray-700 p-4 rounded-lg">
              <div class="relative z-0 w-full mb-6 group">
                <%= f.label :categories, ('Sub Category*'), class: "capitalize block mb-2 text-sm font-medium text-gray-900 dark:text-white" %>
                <%= f.collection_select :groupware_ids, @product.groupwares.where(software_id: @product.software_ids), :id, :name,
                                      { prompt: "Select Sub Product", include_hidden: false },
                                      class: "border border-gray-300 rounded-lg focus:ring-primary-600 focus:border-primary-600 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white dark:focus:ring-blue-500 dark:focus:border-blue-500",
                                      id: "groupware-select",
                                      required: true %>
              </div>
            </div>
          </div>


          <!-- Assignee -->
          <div class="bg-gray-50 dark:bg-gray-700 p-4 rounded-lg">
            <div class="relative z-0 w-full mb-6 group">
              <%= f.label :Assignee, ('Team Members*'), class: "capitalize block mb-2 text-sm font-medium text-gray-900 dark:text-white"  %>
              <%= f.select :user_id, User.with_agent_project_manager_role.order(:first_name, :last_name).map { |user| [user.name, user.id] }, {}, class: "border border-gray-300 rounded-lg focus:ring-primary-600 focus:border-primary-600 block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white dark:focus:ring-blue-500 dark:focus:border-blue-500", placeholder: 'Assign User', required: true %>
            </div>
          </div>

          <!-- Attachments Section -->
          <div class="bg-gray-50 dark:bg-gray-700 p-4 rounded-lg">
            <h3 class="text-lg font-medium text-gray-900 dark:text-white mb-4">Attachments (PDF/DOC)</h3>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <!-- Add Document -->
              <div class="relative z-0 w-full group">
                <!-- Documents Field (use :documents with multiple: true for ActiveStorage) -->
                <div id="documents-container">
                  
                </div>
                <button type="button" id="add-document-button" class="mt-4 p-2 bg-blue-500 text-white rounded">Add Document(s)</button>
              </div>
            </div>
          </div>

          <!-- Dates and Budget -->
          <div class="bg-gray-50 dark:bg-gray-700 p-4 rounded-lg">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
              <!-- Start Date -->
              <div class="relative z-0 w-full group">
                <%= f.label :start_date, 'Start Date*', class: "capitalize block mb-2 text-sm font-medium text-gray-900 dark:text-white"  %>
                <div class="relative">
                  <div class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none">
                    <svg class="w-4 h-4 text-gray-500 dark:text-gray-400" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 20 20">
                      <path d="M20 4a2 2 0 0 0-2-2h-2V1a1 1 0 0 0-2 0v1h-3V1a1 1 0 0 0-2 0v1H6V1a1 1 0 0 0-2 0v1H2a2 2 0 0 0-2 2v2h20V4ZM0 18a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V8H0v10Zm5-8h10a1 1 0 0 1 0 2H5a1 1 0 0 1 0-2Z"/>
                    </svg>
                  </div>
                  <%= f.date_field :start_date, class: "border border-gray-300 rounded-lg focus:ring-primary-600 focus:border-primary-600 block w-full pl-10 p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white dark:focus:ring-blue-500 dark:focus:border-blue-500", required: true %>
                </div>
              </div>

              <!-- End Date -->
              <div class="relative z-0 w-full group">
                <%= f.label :end_date, 'End Date*', class: "capitalize block mb-2 text-sm font-medium text-gray-900 dark:text-white"  %>
                <div class="relative">
                  <div class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none">
                    <svg class="w-4 h-4 text-gray-500 dark:text-gray-400" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 20 20">
                      <path d="M20 4a2 2 0 0 0-2-2h-2V1a1 1 0 0 0-2 0v1h-3V1a1 1 0 0 0-2 0v1H6V1a1 1 0 0 0-2 0v1H2a2 2 0 0 0-2 2v2h20V4ZM0 18a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V8H0v10Zm5-8h10a1 1 0 0 1 0 2H5a1 1 0 0 1 0-2Z"/>
                    </svg>
                  </div>
                  <%= f.date_field :end_date, class: "border border-gray-300 rounded-lg focus:ring-primary-600 focus:border-primary-600 block w-full pl-10 p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white dark:focus:ring-blue-500 dark:focus:border-blue-500", required: true %>
                </div>
              </div>

              <!-- Budget -->
              <div class="relative z-0 w-full group">
                <%= f.label :budget, ('Budget*'), class: "capitalize block mb-2 text-sm font-medium text-gray-900 dark:text-white"  %>
                <div class="relative">
                  <div class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none">
                    <svg class="w-4 h-4 text-gray-500 dark:text-gray-400" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 11 20">
                      <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M1.75 15.363a4.954 4.954 0 0 0 2.638 1.574c2.345.572 4.653-.434 5.155-2.247.502-1.813-1.313-3.79-3.657-4.364-2.344-.574-4.16-2.551-3.658-4.364.502-1.813 2.81-2.818 5.155-2.246A4.97 4.97 0 0 1 10 5.264M6 17.097v1.82m0-17.5v2.138"/>
                    </svg>
                  </div>
                  <%= f.number_field :budget, class: "border border-gray-300 rounded-lg focus:ring-primary-600 focus:border-primary-600 block w-full pl-10 p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white dark:focus:ring-blue-500 dark:focus:border-blue-500", placeholder: '0.00', required: true %>
                </div>
              </div>
            </div>
          </div>

          <!-- Description -->
          <div class="bg-gray-50 dark:bg-gray-700 p-4 rounded-lg">
            <div class="relative z-0 w-full group">
              <%= f.label :title, ('Project Description*'), class: "capitalize block mb-2 text-sm font-medium text-gray-900 dark:text-white"  %>
              <div data-controller="text-limit" data-text-limit-limit-value="3000">
                <p class="text-sm text-gray-500 dark:text-gray-400 mb-2" id="char-count">0/3000</p>
                <%= f.rich_text_area :content, id: "content",
                                   data: { text_limit_target: "content" },
                                   class: "min-h-[200px] border border-gray-300 rounded-lg dark:bg-gray-700 dark:border-gray-600 dark:text-white #{'border-red-500' if @product.errors[:content].any?}",
                                   required: true %>
                <% if @product.errors[:content].any? %>
                  <div class="text-red-500 text-sm mt-2"><%= @product.errors[:content].join(', ') %></div>
                <% end %>
              </div>
            </div>
          </div>

          <!-- Buttons -->
          <div class="flex justify-end space-x-4">
            <%= f.submit "Save Draft", name: "commit", value: "draft", class: "px-4 py-2 text-sm font-medium text-gray-900 bg-white border border-gray-200 rounded-lg hover:bg-gray-100 hover:text-blue-700 focus:z-10 focus:ring-2 focus:ring-blue-700 focus:text-blue-700 dark:bg-gray-800 dark:text-gray-400 dark:border-gray-600 dark:hover:text-white dark:hover:bg-gray-700" %>
            <%= f.submit "Create Project", name: "commit", value: "create", class: "px-4 py-2 text-sm font-medium text-white bg-blue-700 rounded-lg hover:bg-blue-800 focus:ring-4 focus:ring-blue-300 dark:bg-blue-600 dark:hover:bg-blue-700 focus:outline-none dark:focus:ring-blue-800" %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
<% end %>

<script>
  document.getElementById('add-document-button').addEventListener('click', function() {
    const container = document.getElementById('documents-container');
    const timestamp = Date.now(); // Unique identifier for each field set
    const newField = document.createElement('div');
    
    newField.classList.add('document-field', 'flex', 'flex-col', 'mb-4', 'p-3', 'border', 'rounded');
    newField.id = timestamp;
    
    newField.innerHTML = `
      <label class="block mb-1 text-sm font-medium">Document Name</label>
      <input type="text" name="product[documents_attributes][${timestamp}][name]" 
            class="border rounded-lg p-2 mb-2" placeholder="Document Name">
      <label class="block mb-1 text-sm font-medium">Upload File</label>
      <input type="file" name="product[documents_attributes][${timestamp}][file]" 
            class="border rounded-lg p-2">
      <a href="#" class="remove-document text-red-500 mt-2 block" data-id="document-${timestamp}">Remove</a>
    `;

    container.appendChild(newField);
  });

  // Functionality to remove an upload document block based on the ID
  document.addEventListener('click', (e) => {
    if(e.target.classList.contains("remove-document")) {
      e.preventDefault();
      const id = e.target.getAttribute("data-id");
      const element = document.getElementById(id);
      if(element) {
        element.remove();
      }
    }
  })

  // Character counter for description
  document.addEventListener('DOMContentLoaded', function() {
    const contentField = document.querySelector('[data-text-limit-target="content"]');
    const charCount = document.getElementById('char-count');
    
    if (contentField && charCount) {
      contentField.addEventListener('input', function() {
        const length = this.textContent.length;
        charCount.textContent = `${length}/3000`;
        
        if (length > 3000) {
          charCount.classList.add('text-red-500');
          charCount.classList.remove('text-gray-500', 'dark:text-gray-400');
        } else {
          charCount.classList.remove('text-red-500');
          charCount.classList.add('text-gray-500', 'dark:text-gray-400');
        }
      });
      
      // Initialize count
      const initialLength = contentField.textContent.length;
      charCount.textContent = `${initialLength}/3000`;
    }

    document.addEventListener('click', function (e) {
      if (e.target.classList.contains('remove-document')) {
        e.preventDefault();
        e.target.closest('.document-field').remove();
      }
    });
  });
</script>