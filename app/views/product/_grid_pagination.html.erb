<div class="flex items-center justify-between mt-4 border-t border-gray-200 bg-white dark:bg-gray-700 px-4 py-3 sm:px-6">
  <div class="flex flex-1 justify-between sm:hidden">
    <% if @page > 1 %>
      <%= link_to 'Previous', product_index_path(page: @page - 1, query: params[:query]), class: "relative inline-flex items-center rounded-md border border-gray-300 bg-white px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50" %>
    <% end %>
    <% if @page < @total_pages %>
      <%= link_to 'Next', product_index_path(page: @page + 1, query: params[:query]), class: "relative ml-3 inline-flex items-center rounded-md border border-gray-300 bg-white px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50" %>
    <% end %>
  </div>
  <div class="hidden sm:flex sm:flex-1 sm:items-center sm:justify-between">
    <div>
      <p class="text-sm">
        Showing
        <span class="font-medium"><%= @start_count %></span>
        to
        <span class="font-medium"><%= @end_count %></span>
        of
        <span class="font-medium"><%= @total_count %></span>
        results
      </p>
    </div>
    <div>
      <nav class="isolate inline-flex -space-x-px rounded-md shadow-xs" aria-label="Pagination">
        <%# First page %>
        <% if @page > 1 %>
          <%= link_to  product_index_path(@product, page: 1, query: params[:query]) do %>
            <span class="sr-only">First</span>
            <svg class="size-10" viewBox="0 0 20 20" fill="currentColor"><path d="M13 15l-5-5 5-5"/></svg>
          <% end %>

          <%# Previous page %>

          <%= link_to product_index_path(@product, page: @page - 1, query: params[:query]) do %>
            <span class="sr-only">Previous</span>
            <svg class="size-10" viewBox="0 0 20 20" fill="currentColor"><path d="M11.78 5.22a.75.75 0 0 1 0 1.06L8.06 10l3.72 3.72a.75.75 0 1 1-1.06 1.06l-4.25-4.25a.75.75 0 0 1 0-1.06l4.25-4.25a.75.75 0 0 1 1.06 0Z"/></svg>
          <% end %>
        <% end %>
        <%# Page numbers %>
        <% (1..@total_pages).each do |p| %>
          <% if p == @page %>
            <span aria-current="page" class="relative z-10 inline-flex items-center bg-indigo-600 px-4 py-2 text-sm font-semibold focus:z-20"><%= p %></span>
          <% elsif p == 1 || p == @total_pages || (p >= @page - 2 && p <= @page + 2) %>
            <%= link_to p, product_index_path(page: p, query: params[:query]), class: "relative inline-flex items-center px-4 py-2 text-sm font-semibold ring-1 ring-gray-300 ring-inset hover:bg-gray-50 dark:hover:bg-gray-600 focus:z-20" %>
          <% elsif p == @page - 3 || p == @page + 3 %>
            <span class="relative inline-flex items-center px-4 py-2 text-sm font-semibold ring-1 ring-gray-300 ring-inset">...</span>
          <% end %>
        <% end %>
        <%# Next page %>
        <% if @page < @total_pages %>
          <%= link_to product_index_path(page: @page + 1, query: params[:query]) do %>
            <span class="sr-only">Next</span>
            <svg class="size-10" viewBox="0 0 20 20" fill="currentColor"><path d="M8.22 5.22a.75.75 0 0 1 1.06 0l4.25 4.25a.75.75 0 0 1 0 1.06l-4.25 4.25a.75.75 0 0 1-1.06-1.06L11.94 10 8.22 6.28a.75.75 0 0 1 0-1.06Z"/></svg>
          <% end %>

          <%= link_to product_index_path(page: @total_pages, query: params[:query]) do %>
            <span class="sr-only">Last</span>
            <svg class="size-10" viewBox="0 0 20 20" fill="currentColor">
              <path d="M7 5l5 5-5 5"/>
            </svg>
          <% end %>
        <% end %>
      </nav>
    </div>
  </div>
</div>