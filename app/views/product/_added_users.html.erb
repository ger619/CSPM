<h3 class="font-semibold text-lg text-gray-800 dark:text-gray-200 mb-3">Assigned Agents</h3>
<div class="flex flex-wrap gap-2 items-center">
  <% if @product.users.any? %>
    <% @product.users.each do |user| %>
      <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-200">
          <% if user.name.present? %>
            <%= user.name %>
          <% else %>
            <%= truncate(user.email, length: 15, omission: '...') %>
          <% end %>
      </span>
    <% end %>
  <% else %>
    <p class="text-gray-600 dark:text-gray-300">No users assigned to this product yet.</p>
  <% end %>
</div>