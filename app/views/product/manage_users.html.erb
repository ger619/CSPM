<%= turbo_frame_tag "modal" do %>

  <% if flash[:notice] %>
    <div class="bg-[#1a237e] border border-[#4caf50] text-white px-4 py-3 rounded mb-4 shadow-md">
      <p><%= flash[:notice] %></p>
    </div>
  <% elsif flash[:alert] %>
    <div class="bg-red-600 border border-red-400 text-white px-4 py-3 rounded mb-4 shadow-md">
      <p><%= flash[:alert] %></p>
    </div>
  <% end %>
  
  <div class="fixed inset-0 bg-black bg-opacity-50 flex justify-center items-center z-50">
    <div class="bg-white dark:bg-gray-800 p-6 rounded-lg shadow-xl w-full max-w-2xl relative">
      <!-- Close Button -->
      <%= link_to "X", "#", data: {
        controller: "modal",
        action: "modal#close"
      }, class: "absolute top-3 right-3 text-xl font-bold text-gray-500 hover:text-gray-700 dark:text-gray-300 dark:hover:text-gray-100" %>

      <!-- Header -->
      <h2 class="text-2xl font-semibold text-gray-800 dark:text-gray-100 mb-6">Manage Product Users</h2>

      <!-- Main Content -->
      <div class="space-y-6">
        <!-- Assigned Agents Section -->
        <div class="bg-gray-50 dark:bg-gray-700 p-4 rounded-lg">
          <%= render 'product/added_users' %>
          
        </div>

        <!-- Add/Remove Users Section -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <!-- Add Users -->
          <div class="bg-gray-50 dark:bg-gray-700 p-4 rounded-lg">
            <%= render 'product/add_users' %>
          </div>

          <!-- Remove Users -->
          <% if @product.users.present? %>
            <div class="bg-gray-50 dark:bg-gray-700 p-4 rounded-lg">
              <%= render 'product/remove_user' %>
            </div>
          <% end %>
        </div>
      </div>

      <!-- Cancel Button -->
      <div class="flex justify-end mt-6">
        <%= link_to "Close", "#", data: {
            controller: "modal",
            action: "modal#close"
        }, class: "px-4 py-2 text-sm font-medium text-white bg-red-600 hover:bg-red-700 rounded-lg dark:bg-red-700 dark:hover:bg-red-800" %>
      </div>
    </div>
  </div>
<% end %>