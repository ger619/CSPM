<div class="grid grid-cols-2 mb-4">
  <!-- Tickets topbar left side -->
  <div class="flex items-center gap-3 sm:gap-4">
    <div class="flex-shrink-0">
      <% if @product.image.present? %>
        <%= image_tag(@product.image, class: 'w-12 h-12 sm:w-14 sm:h-14 md:w-16 md:h-16 rounded-full object-cover') %>
      <% else %>
        <%= image_tag 'default.png', class: 'w-12 h-12 sm:w-14 sm:h-14 md:w-16 md:h-16 rounded-full object-cover' %>
      <% end %>
    </div>
    <div class="flex flex-col">
      <h1 class="text-lg sm:text-xl md:text-2xl font-semibold"><%= @product.client.name %></h1>
      <p class="text-xs sm:text-sm md:text-base"><%= @product.groupwares.map(&:name).join(', ').presence || "Client Description if any" %>
    </div>
    <div class="flex flex-row items-center gap-2">
      <h1 class="text-md">Due date: <%= @product.end_date.strftime("%d %b %Y") %></h1>
      <p class="text-md <%= 'text-red-500' if @days_remaining.to_i < 10 %>">
        <%= pluralize(@days_remaining, 'day') %> remaining
      </p>
    </div>


  </div>

  <!-- Tickets topbar right side -->
  <div class="flex justify-end items-center gap-3">
    <!-- If there is no board created that is todo, this will not show. Show create first board -->
      <%= link_to new_product_task_path(@product), class: 'bg-[#3F8CFF] hover:bg-[#3A81EB] p-2 rounded font-bold rounded-lg text-slate-100', id: 'button' do %>
            Add Task
      <% end %>
    
    <% if current_user.has_role?(:admin) || current_user.has_role?('project manager') %>
      <%= link_to manage_users_product_path(@product), data: { turbo_frame: "modal" }, class: "flex items-center gap-2 border-2 border-blue-500 bg-white hover:bg-blue-500 px-4 py-2 rounded-lg text-blue-500 hover:text-white font-medium transition-colors duration-200" do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
          <path d="M9 6a3 3 0 11-6 0 3 3 0 016 0zM17 6a3 3 0 11-6 0 3 3 0 016 0zM12.93 17c.046-.327.07-.66.07-1a6.97 6.97 0 00-1.5-4.33A5 5 0 0119 16v1h-6.07zM6 11a5 5 0 015 5v1H1v-1a5 5 0 015-5z" />
        </svg>
        <span>Manage Users</span>
      <% end %>
    <% end %>
  </div>
</div>

<% if flash[:prompt] %>
  <div id="custom-alert" class="fixed inset-0 bg-black bg-opacity-50 flex justify-center items-center z-50">
    <div class="bg-white rounded-lg p-6 max-w-sm w-full shadow-lg">
      <h2 class="text-xl font-semibold mb-4 text-gray-800">Notice</h2>
      <p class="text-gray-600"><%= flash[:prompt] %></p>
      <div class="mt-4 text-right">
        <button id="close-alert" class="bg-blue-500 text-white px-4 py-2 rounded hover:bg-blue-600">
          OK
        </button>
      </div>
    </div>
  </div>

  <script type="text/javascript">
    document.addEventListener("turbo:load", function() {
      const alertBox = document.getElementById("custom-alert");
      const closeButton = document.getElementById("close-alert");

      closeButton.addEventListener("click", function() {
        alertBox.remove(); // Completely removes the modal from the DOM
      });
    });
  </script>
<% end %>

