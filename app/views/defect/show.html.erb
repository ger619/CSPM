<% provide(:title, "QA Details for: #{@defect.name}") %>

<% if flash[:notice] %>
  <div class="bg-[#1a237e] border border-[#4caf50] text-white px-4 py-3 rounded mb-4 shadow-md">
    <p><%= flash[:notice] %></p>
  </div>
<% elsif flash[:alert] %>
  <div class="bg-red-600 border border-red-400 text-white px-4 py-3 rounded mb-4 shadow-md">
    <p><%= flash[:alert] %></p>
  </div>
<% end %>

<div class="p-2">
  <!-- Topbar and Alert -->
  <%= render 'bugs/top_bug' %>

  <%= render 'layouts/alert', class: "" %>
  <div class="grid grid-cols-3 gap-4 mb-4">
    <div class="col-span-1">
      <%= render 'defect/add_defect' %>
    </div>
  </div>
  <div class="flex pt-2 mb-4 rounded bg-gray-50 dark:bg-gray-800 w-full">

    <%= render 'bugs/bugs_view' %>

  </div>
</div>

