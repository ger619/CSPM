<%= turbo_frame_tag "modal" do %>
  <div class="fixed inset-0 bg-black bg-opacity-50 flex justify-center items-center z-50">
    <div class="bg-white p-6 rounded-lg shadow-xl w-full max-w-4xl relative space-y-6">
      
      <!-- Close Button -->
      <button type="button"
              data-action="click->modal#close"
              class="absolute top-3 right-3 text-gray-500 hover:text-gray-800 text-xl font-bold">
        &times;
      </button>

      <!-- Header -->
      <h2 class="text-2xl font-semibold text-gray-800 mb-4">Manage Project Users</h2>

      <!-- Assign People -->
      <%= render 'assign_people' %>

      <!-- Add Assignments -->
      <%= render 'project/add_assign' %>

      <!-- Add Teams -->
      <%= render 'project/add_teams' %>

      <!-- Cancel Button -->
      <div class="flex justify-end">
        <%= link_to "Cancel", "#", data: {
          controller: "modal",
          action: "modal#close"
        }, class: "text-sm text-red-600 hover:text-red-800 font-medium" %>
      </div>

    </div>
  </div>
<% end %>
