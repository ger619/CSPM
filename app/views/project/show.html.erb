<% provide(:title, "Support Desk: #{@project.title}") %>

<%= render 'tickets/ticket_topbar' %>

<div class="bg-white rounded-lg shadow p-6 mb-6">
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
    <!-- First Column -->
    <div class="space-y-2">
      <div class="grid grid-cols-[auto_1fr_auto] items-center gap-3 sm:gap-4">
        <div class="flex-shrink-0">
          <svg class="h-8 w-8 text-gray-400" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
            <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-6-3a2 2 0 11-4 0 2 2 0 014 0zm-2 4a5 5 0 00-4.546 2.916A5.986 5.986 0 0010 16a5.986 5.986 0 004.546-2.084A5 5 0 0010 11z" clip-rule="evenodd"></path>
          </svg>
        </div>
        <div class="flex flex-col">
          <h2 class="text-lg font-semibold text-gray-500">Support Desk Manager</h2>
          <p class="text-xl font-medium text-gray-900 ml-7"><%= @project.user&.name || 'No Project Manager Assigned' %></p>
        </div>
      </div>

      <div class="grid grid-cols-[auto_1fr_auto] items-center gap-3 sm:gap-4">
        <div class="flex-shrink-0">
          <svg class="h-8 w-8 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd"></path>
          </svg>
        </div>
        <div class="flex flex-col">
          <h2 class="text-lg font-semibold text-gray-500">Date to Commence</h2>
          <p class="text-xl font-medium text-gray-900 ml-7"><%= @project.start_date.strftime("%d %b %Y") %></p>
        </div>
      </div>
    </div>
    
    <!-- Second Column -->
    <div class="space-y-4">
      <div class="grid grid-cols-[auto_1fr_auto] items-center gap-3 sm:gap-4">
        <div class="flex-shrink-0">
          <svg class="h-8 w-8 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd"></path>
          </svg>
        </div>
        <div class="flex flex-col">
          <h2 class="text-lg font-semibold text-gray-500">My Tickets</h2>
          <p class="text-3xl font-bold text-gray-900"><%= @assigned_tickets_count %></p>
        </div>
        <div class="flex items-center justify-end">
          <%= link_to "View",
            project_path(@project, filter: 'Assigned'),
              class: "bg-blue-600 text-white font-medium rounded px-4 py-2 no-underline hover:bg-blue-700 transition" %>
        </div>
      </div>

      <!-- Block 2 -->
      <div class="grid grid-cols-[auto_1fr_auto] items-center gap-3 sm:gap-4">
        <div class="flex-shrink-0">
          <svg class="h-8 w-8 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd"></path>
          </svg>
        </div>
        <div class="flex flex-col">
          <h2 class="text-lg font-semibold text-gray-500">Assigned & Closed</h2>
          <p class="text-3xl font-bold text-gray-900"><%= @closed_assigned_tickets %></p>
        </div>
        <div class="flex items-center justify-end">
          <%= link_to "View",
              project_path(@project, filter: 'Assigned'),
              class: "bg-blue-600 text-white font-medium rounded px-4 py-2 no-underline hover:bg-blue-700 transition" %>
        </div>
      </div>

      <!-- Block 3 -->
      <div class="grid grid-cols-[auto_1fr_auto] items-center gap-3 sm:gap-4">
        <div class="flex-shrink-0">
          <svg class="h-8 w-8 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd"></path>
          </svg>
        </div>
        <div class="flex flex-col">
          <h2 class="text-lg font-semibold text-gray-500">SLA on Target Response</h2>
          <p class="text-3xl font-bold text-gray-900"><%= @breached_target_tickets_count %></p>
        </div>
        <div class="flex items-center justify-end">
          <%= link_to "View",
              project_path(@project, filter: 'Assigned'),
              class: "bg-blue-600 text-white font-medium rounded px-4 py-2 no-underline hover:bg-blue-700 transition" %>
        </div>
      </div>
    </div>

    
    <!-- Third Column -->
    <div class="px-16 grid grid-cols-[auto_1fr_auto] gap-3 sm:gap-4">
      <div class="flex-shrink-0">
        <svg class="h-8 w-8 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd"></path>
        </svg>
      </div>
      <div class="flex flex-col">
        <h2 class="text-lg font-semibold text-gray-500">Products</h2>
        <p class="text-xl font-medium text-gray-900">
          <% if @project.softwares.any? %>
            <ul>
              <% if @project.softwares.any? %>
            <% @project.softwares.each do |software| %>
              <ul>
                <% software.groupwares.each do |groupware| %>
                    <li>
                      <%= groupware.name %> 
                    </li>
                <% end %>
              </ul>
            <% end %>
          <% else %>
            No sub-product present
          <% end %>
            </ul>
          <% else %>
            No Product Assigned
          <% end %>
        </p>
      </div>
    </div>
  </div>
</div>









<div class="border-2 border-gray-200 rounded-lg dark:border-gray-700">
  
  <div class="flex pt-2 mb-4 rounded bg-gray-50 dark:bg-gray-800 min-h-[300px] w-full">
    <% if @project.assigned_to?(current_user) or current_user.has_role?(:admin) or current_user.has_role?(:agent) or current_user.has_role?(:observer) %>
      <%= render 'tickets/ticket' %>
    <% end %>
  </div>
  <h1>Total Tickets:
    <span class="font-medium">
      <%= @ticket_count %>
    </span>
  </h1>
</div>

<div class="flex flex-col md:flex-row gap-10 mt-5">
  <!-- Pagination Controls -->
  <div class="pagination">
    <% if @page > 1 %>
      <%= link_to 'Previous', project_path(@project, params.permit!.merge(page: @page - 1)), class: 'mb-4 h-12 bg-[#3F8CFF] hover:bg-[#3A81EB] p-3 rounded font-bold rounded-lg text-slate-100' %>
    <% end %>

    <span>Page <%= @page %> of <%= @total_pages %></span>

    <% if @page < @total_pages %>
      <%= link_to 'Next', project_path(@project, params.permit!.merge(page: @page + 1)), class: 'mb-4 h-12 bg-[#3F8CFF] hover:bg-[#3A81EB] p-3 rounded font-bold rounded-lg text-slate-100' %>
    <% end %>
  </div>
</div>