<% provide(:title, "Support Desks") %>

<% if flash[:notice] %>
  <div class="bg-[#1a237e] border border-[#4caf50] text-white px-4 py-3 rounded mb-4 shadow-md">
    <p><%= flash[:notice] %></p>
  </div>
<% elsif flash[:alert] %>
  <div class="bg-red-600 border border-red-400 text-white px-4 py-3 rounded mb-4 shadow-md">
    <p><%= flash[:alert] %></p>
  </div>
<% end %>

  <!-- Topbar Section -->
  <div class="mb-4">
    <%= render 'project/topbar' %>
  </div>
  <!-- Project Table Section -->
  <div class="overflow-x-auto">
    <%= render 'project/project_table' %>
  </div>
  <!-- Pagination Section -->
  <div class="flex flex-col sm:flex-row justify-between items-center gap-4 mt-5">
    <div class="flex items-center gap-4">
      <% if @page > 1 %>
        <%= link_to 'Previous',
          project_index_path(page: @page - 1, query: params[:query]),
          class: 'bg-blue-600 hover:bg-blue-500 px-4 rounded text-white text-sm font-semibold transition-all p-2 uppercase' %>
      <% end %>
      <span class="text-sm font-medium">
        Page <%= @page %> of <%= @total_pages %>
      </span>
      <% if @page < @total_pages %>
        <%= link_to 'Next',
          project_index_path(page: @page + 1, query: params[:query]),
          class: 'bg-blue-600 hover:bg-blue-500 px-4 rounded text-white text-sm font-semibold transition-all p-2 uppercase' %>
      <% end %>
    </div>
  </div>
