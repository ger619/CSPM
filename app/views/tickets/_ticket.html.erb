<div class="w-full">
  <%= render 'tickets/search_q' %>

  <div class="overflow-x-auto border border-gray-200 rounded-lg">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Date of Issue</th>
          <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Ticket ID</th>
          <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Issue Type</th>
          <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Severity</th>
          <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Summary</th>
          <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Assigned To</th>
          <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
          <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Progress</th>
          <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Reported By</th>
          <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Last Updated</th>
          <th scope="col" class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
          <% if current_user.has_role?(:admin) || current_user.has_role?(:agent) || current_user.has_role?('project manager') %>
            <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider hide-on-sidebar">Edits</th>
            <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider hide-on-sidebar">Last Edit</th>
          <% end %>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% @ticket.each do |ticket| %>
          <% if ticket.present? %>
            <tr class="hover:bg-gray-50">
              <!-- Date of Issue -->
              <td class="px-4 py-4 whitespace-nowrap text-sm text-gray-500">
                <%= link_to ticket.created_at.strftime("%d %b %Y"), project_ticket_path(ticket.project, ticket) %>
              </td>
              
              <!-- Ticket ID -->
              <td class="px-4 py-4 whitespace-nowrap text-sm font-medium text-gray-900 uppercase">
                <% if ticket.unique_id.present? %>
                  <%= link_to ticket.unique_id, project_ticket_path(ticket.project, ticket) %>
                <% end %>
              </td>
              
              <!-- Issue Type -->
              <td class="px-4 py-4 whitespace-nowrap text-sm text-gray-500">
                <%= link_to ticket.issue, project_ticket_path(ticket.project, ticket) %>
              </td>
              
              <!-- Severity -->
              <td class="px-4 py-4 whitespace-nowrap">
                <% if ticket.priority == 'SEVERITY 1' %>
                  <span class="px-2 py-1 text-xs font-bold rounded-full bg-red-100 text-red-800">SEV-1</span>
                <% elsif ticket.priority == 'SEVERITY 2' %>
                  <span class="px-2 py-1 text-xs font-bold rounded-full bg-orange-100 text-orange-800">SEV-2</span>
                <% elsif ticket.priority == 'SEVERITY 3' %>
                  <span class="px-2 py-1 text-xs font-bold rounded-full bg-yellow-100 text-yellow-800">SEV-3</span>
                <% else %>
                  <span class="px-2 py-1 text-xs font-bold rounded-full bg-blue-100 text-blue-800">SEV-4</span>
                <% end %>
              </td>
              
              <!-- Summary -->
              
              <td class="grid grid-cols-[auto_1fr_auto] items-center gap-3 sm:gap-4">
                <div class="flex-shrink-0">
                  <svg class="h-8 w-8 text-gray-400" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
                    <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-6-3a2 2 0 11-4 0 2 2 0 014 0zm-2 4a5 5 0 00-4.546 2.916A5.986 5.986 0 0010 16a5.986 5.986 0 004.546-2.084A5 5 0 0010 11z" clip-rule="evenodd"></path>
                  </svg>
                </div>
                <div class="flex flex-col">
                  <div class="font-medium"><%= ticket.subject.truncate(50) if ticket.subject.present? %></div>
                  <% if ticket.subject.present? %>
                    <div class="text-gray-500 mt-1"><%= ticket.subject.truncate(70) %></div>
                  <% end %>
                </div>
              </td>
              
              <!-- Assigned To -->
              <td class="px-4 py-4 whitespace-nowrap">
                <% ticket.users.each do |user| %>
                  <% if user.name.present? %>
                    <div class="flex items-center">
                      <div class="flex-shrink-0 h-8 w-8 rounded-full flex items-center justify-center">
                        <span class="text-xs font-medium text-gray-600"><%= user.name %></span>
                      </div>
                    </div>
                  <% end %>
                <% end %>
              </td>
              
              <!-- Status -->
              <td class="px-4 py-4 whitespace-nowrap">
                <% ticket.statuses.each do |status| %>
                  <% case status.name %>
                    <% when 'Resolved' %>
                      <span class="px-2 py-1 text-xs font-semibold rounded-full bg-green-100 text-green-800">Resolved</span>
                    <% when 'Closed' %>
                      <span class="px-2 py-1 text-xs font-semibold rounded-full bg-gray-100 text-gray-800">Closed</span>
                    <% when 'Reopened' %>
                      <span class="px-2 py-1 text-xs font-semibold rounded-full bg-red-100 text-red-800">Reopened</span>
                    <% when 'New' %>
                      <span class="px-2 py-1 text-xs font-semibold rounded-full bg-red-100 text-red-800">New</span>
                    <% when 'Under Development' %>
                      <span class="px-2 py-1 text-xs font-semibold rounded-full bg-blue-100 text-blue-800">Under Dev</span>
                    <% when 'Work in Progress' %>
                      <span class="px-2 py-1 text-xs font-semibold rounded-full bg-gray-100 text-gray-800">WIP</span>
                    <% when 'QA Testing' %>
                      <span class="px-2 py-1 text-xs font-semibold rounded-full bg-pink-100 text-pink-800">QA Testing</span>
                    <% when 'Awaiting Build' %>
                      <span class="px-2 py-1 text-xs font-semibold rounded-full border border-gray-300">Awaiting Build</span>
                    <% when 'Client Confirmation Pending' %>
                      <span class="px-2 py-1 text-xs font-semibold rounded-full bg-purple-100 text-purple-800">Client Confirm</span>
                    <% when 'On-Hold' %>
                      <span class="px-2 py-1 text-xs font-semibold rounded-full bg-yellow-100 text-yellow-800">On-Hold</span>
                    <% when 'Assigned' %>
                      <span class="px-2 py-1 text-xs font-semibold rounded-full bg-blue-100 text-blue-800">Assigned</span>
                    <% when 'Approved' %>
                      <span class="px-2 py-1 text-xs font-semibold rounded-full bg-green-100 text-green-800">Approved</span>
                    <% when 'Pending' %>
                      <span class="px-2 py-1 text-xs font-semibold rounded-full bg-gradient-to-r from-green-100 to-gray-100">Pending</span>
                    <% when 'Declined' %>
                      <span class="px-2 py-1 text-xs font-semibold rounded-full bg-gray-100 text-gray-800">Declined</span>
                  <% end %>
                <% end %>
              </td>
              
              <!-- Progress Bar -->
              <td class="px-4 py-4 whitespace-nowrap">
                <div class="flex items-center">
                  <div class="w-16 mr-2 text-xs text-right text-gray-500">
                    <%= ticket.progress_percentage || 0 %>%
                  </div>
                  <div class="w-full bg-gray-200 rounded-full h-2">
                    <div class="h-2 rounded-full <%= if ticket.progress_percentage.nil?
                                                      'bg-gray-400'
                                                    elsif ticket.progress_percentage < 30
                                                      'bg-red-600'
                                                    elsif ticket.progress_percentage < 60
                                                      'bg-blue-600'
                                                    else
                                                      ticket.progress_percentage >= 100 ? 'bg-black' : 'bg-green-600'
                                                    end %>" 
                         style="width: <%= ticket.progress_percentage || 0 %>%">
                    </div>
                  </div>
                </div>
              </td>
              
              <!-- Reported By -->
              <td class="px-4 py-4 whitespace-nowrap text-sm text-gray-500">
                <% if ticket.user.name.present? %>
                  <div class="flex items-center">
                    <div class="flex-shrink-0 h-8 w-8 rounded-full flex items-center justify-center">
                      <span class="text-xs font-medium text-gray-600"><%= ticket.user.name %></span>
                    </div>
                  </div>
                <% end %>
              </td>
              
              <!-- Last Updated -->
              <td class="px-4 py-4 whitespace-nowrap text-sm text-gray-500">
                <% if ticket.add_statuses.present? %>
                  <%= ticket.add_statuses.first.updated_at.strftime('%H:%M %d %b %Y') %>
                <% end %>
              </td>
              
              <!-- Actions -->
              <td class="px-4 py-4 whitespace-nowrap text-right text-sm font-medium">
  <div class="relative inline-block text-left">
    <div>
      <button
        type="button"
        class="inline-flex justify-center w-8 h-8 rounded-full hover:bg-gray-100 focus:outline-none"
        id="menu-button-<%= ticket.id %>"
        aria-expanded="false"
        aria-haspopup="true"
        onclick="toggleDropdown('<%= ticket.id %>')">
        <svg class="w-5 h-5 text-gray-500" 
             xmlns="http://www.w3.org/2000/svg" 
             viewBox="0 0 20 20" 
             fill="currentColor">
          <path d="M10 6a2 2 0 110-4 2 2 0 010 4zM10 12a2 2 0 110-4 2 2 0 010 4zM10 18a2 2 0 110-4 2 2 0 010 4z" />
        </svg>
      </button>
    </div>

    <div id="dropdown-<%= ticket.id %>" 
         class="hidden origin-top-right absolute right-0 mt-2 w-56 rounded-md shadow-lg bg-white ring-1 ring-black ring-opacity-5 focus:outline-none z-10">
      <div class="py-1" role="none">
        <%= link_to 'View',
            project_ticket_path(ticket.project, ticket),
            class: 'block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 hover:text-gray-900' %>

        <% if can?(:edit, ticket) %>
          <%= link_to 'Edit',
              edit_project_ticket_path(ticket.project, ticket),
              class: 'block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 hover:text-gray-900' %>
        <% end %>

        <% if can?(:destroy, ticket) %>
          <%= button_to 'Delete',
              [ticket.project, ticket],
              method: :delete,
              data: { turbo_confirm: 'Are you sure?' },
              class: 'block w-full text-left px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 hover:text-gray-900' %>
        <% end %>
      </div>
    </div>
  </div>
</td>


              
              <% if current_user.has_role?(:admin) || current_user.has_role?(:agent) || current_user.has_role?('project manager') %>
                <td class="px-4 py-4 whitespace-nowrap text-sm text-gray-500 text-center hide-on-sidebar">
                  <%= ticket.update_count %>
                </td>
                <td class="px-4 py-4 whitespace-nowrap text-sm text-gray-500 text-center hide-on-sidebar">
                  <%= ticket.last_updated_at ? ticket.last_updated_at.strftime("%T") : 'Never' %>
                </td>
              <% end %>
            </tr>
          <% end %>
        <% end %>
      </tbody>
    </table>
  </div>
</div>

<script>
document.addEventListener("turbo:load", function() {
  // Sidebar column visibility toggle
  const sidebar = document.getElementById("sidebar");
  const tableColumns = document.querySelectorAll(".hide-on-sidebar");

  window.toggleDropdown = function(ticketId) {
    const dropdown = document.getElementById(`dropdown-${ticketId}`);
    if (!dropdown) return;

    dropdown.classList.toggle('hidden');

    // Close when clicking outside
    const closeDropdown = function(event) {
      if (!dropdown.contains(event.target) && event.target.id !== `menu-button-${ticketId}`) {
        dropdown.classList.add('hidden');
        document.removeEventListener('click', closeDropdown);
      }
    };
    document.addEventListener('click', closeDropdown);
  };
  
  function toggleColumns() {
    const isExpanded = sidebar.classList.contains("w-64");
    tableColumns.forEach(col => {
      col.style.display = isExpanded ? "none" : "table-cell";
    });
  }
  
  // Initialize and observe sidebar changes
  if (sidebar) {
    toggleColumns();
    const observer = new MutationObserver(toggleColumns);
    observer.observe(sidebar, { attributes: true, attributeFilter: ['class'] });
  }

  // Sorting functionality
  document.querySelectorAll("th[scope='col']").forEach(header => {
    header.addEventListener("click", function() {
      const table = this.closest("table");
      const headerIndex = Array.from(this.parentElement.children).indexOf(this);
      const tbody = table.querySelector("tbody");
      const rows = Array.from(tbody.querySelectorAll("tr"));
      const isAscending = !this.classList.contains("asc");
      
      // Reset all headers
      table.querySelectorAll("th[scope='col']").forEach(h => {
        h.classList.remove("asc", "desc");
      });
      
      // Set current sort direction
      this.classList.add(isAscending ? "asc" : "desc");
      
      // Sort rows
      rows.sort((rowA, rowB) => {
        const cellA = rowA.children[headerIndex].textContent.trim();
        const cellB = rowB.children[headerIndex].textContent.trim();
        
        // Handle numeric values
        if (!isNaN(cellA) {
          return isAscending ? cellA - cellB : cellB - cellA;
        }
        
        // Handle dates
        const dateA = Date.parse(cellA);
        const dateB = Date.parse(cellB);
        if (!isNaN(dateA) {
          return isAscending ? dateA - dateB : dateB - dateA;
        }
        
        // Default string comparison
        return isAscending ? cellA.localeCompare(cellB) : cellB.localeCompare(cellA);
      });
      
      // Re-insert rows
      rows.forEach(row => tbody.appendChild(row));
    });
  });
});
</script>