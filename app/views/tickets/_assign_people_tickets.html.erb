<% if current_user.has_role?(:admin) || current_user.has_role?('project manager') || current_user.has_role?(:agent) %>
  <div class="col-span-2 mt-6" data-controller="status-modal">
    <div class="flex items-center justify-between mb-2">
      <div class="text-sm font-semibold uppercase tracking-wider">Assigned Users</div>
      <% unless (@ticket.statuses.first&.name == 'Closed' or @ticket.statuses.first&.name == 'Resolved') && !current_user.has_role?(:admin) %>
        <button
            data-action="click->status-modal#openModal"
            class="ml-2 px-2 py-2 rounded-md bg-blue-600 text-white hover:bg-blue-700 dark:bg-blue-500 dark:hover:bg-blue-600 focus:outline-none focus:ring-2 focus:ring-blue-300 dark:focus:ring-blue-400 transition"
            aria-label="Assign users"
          >
            Select
          </button>
      <% end %>

    </div>

    <div class="flex flex-wrap items-center gap-2">
      <% if @ticket.users.any? %>
        <% @ticket.users.each do |user| %>
          <span class="text-base font-medium">
            <%= user.name %>
            <% unless user == @ticket.users.last %>,
          <% end %>
          </span>
        <% end %>
      <% else %>
        <p class="text-red-500 text-sm">
          No agents assigned. Please assign at least one agent to this ticket.
        </p>
      <% end %>
    </div>

    <!-- Assign Users Modal -->
    <div class="hidden fixed inset-0 bg-gray-500 bg-opacity-50 overflow-y-auto h-full w-full z-50" 
         data-status-modal-target="modal">
      <div class="relative top-20 mx-auto p-5 border w-96 shadow-lg rounded-md bg-white dark:bg-gray-800">
        <div class="flex justify-between items-center mb-4">
          <h3 class="text-lg font-medium">Assign Users Modal</h3>
          <button
            data-action="click->status-modal#closeModal"
            class="focus:outline-none text-gray-500 hover:text-gray-700"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>

        <%= form_with url: assign_tag_project_ticket_path(@project, @ticket, data: { turbo: false }), local: true do %>
          <div class="mb-4">
            <%= label_tag :user_id, "Select User", class: "block text-sm font-medium mb-1" %>
            <% available_users = User.with_assigned_role.where.not(id: @ticket.users.pluck(:id)).where(id: @project.users.pluck(:id)).order(:first_name).distinct %>
            <% if available_users.any? %>
              <%= select_tag :user_id, options_from_collection_for_select(available_users, :id, :name || :email),
                  class: "mt-1 block w-full pl-3 pr-10 py-2 text-base dark:bg-gray-700 border-gray-300 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm rounded-md" %>
            <% else %>
              <p class="text-sm">No available users to assign.</p>
            <% end %>
          </div>

          <div class="flex justify-end space-x-3">
            <button
              type="button"
              data-action="click->status-modal#closeModal"
              class="px-4 py-2 text-sm font-medium border border-gray-300 rounded-md hover:bg-gray-50 dark:hover:bg-gray-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500"
            >
              Cancel
            </button>
            <% if available_users.any? %>
              <%= submit_tag "Assign User", class: "px-4 py-2 text-sm font-medium text-white bg-indigo-600 border border-transparent rounded-md hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" %>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
<% end %>