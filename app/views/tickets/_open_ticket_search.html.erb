<div class="grid grid-cols-2 mb-4 ">
  <div class="grid col-span-1">
    <div class="flex gap-1">
      <%= button_to project_index_path, method: :get, class: 'bg-[#3F8CFF] hover:bg-[#3A81EB] p-2 rounded font-bold rounded-lg text-slate-100' do %>
        &#8656; Back
      <% end %>
    </div>
  </div>
  <!-- Search on the right -->
  <div class="grid col-span-1 justify-end">
    <div class="flex flex-col md:flex-row items-start md:items-center w-full">
      <%= form_with url: all_open_tickets_project_tickets_path(@project), method: :get, local: true do %>
        <input type="text" name="search" value="<%= params[:search] %>" placeholder="Search tickets..." class="border border-gray-300 h-10 w-96 px-5 pr-10 rounded-md font-medium placeholder-current focus:outline-none dark:bg-gray-700 dark:border-gray-50 dark:text-slate-100" />
        <button type="submit" class='bg-[#3F8CFF] hover:bg-[#3A81EB] p-2 rounded font-bold rounded-lg text-slate-100 mr-2'>Search</button>
      <% end %>
      <%= form_with url: all_open_tickets_project_tickets_path(@project), method: :get, local: true do %>
        <button type="submit" class='bg-[#3F8CFF] hover:bg-[#3A81EB] p-2 rounded font-bold rounded-lg text-slate-100 mr-2'>Clear</button>
      <% end %>
    </div>
  </div>
</div>
<% if flash[:prompt] %>
  <div id="custom-alert" 
       class="fixed inset-0 bg-black bg-opacity-50 flex justify-center items-center z-50"
       data-controller="open-ticket-search"
       data-open-ticket-search-target="alert">
    <div class="bg-white rounded-lg p-6 max-w-sm w-full shadow-lg">
      <h2 class="text-xl font-semibold mb-4 text-gray-800">Notice</h2>
      <p class="text-gray-600"><%= flash[:prompt] %></p>
      <div class="mt-4 text-right">
        <button id="close-alert" 
                class="bg-blue-500 text-white px-4 py-2 rounded hover:bg-blue-600"
                data-action="click->open-ticket-search#closeAlert">
          OK
        </button>
      </div>
    </div>
  </div>
<% end %>