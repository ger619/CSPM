<%= turbo_frame_tag "modal" do %>

<div class="fixed inset-y-0 right-0 z-50 w-full max-w-2xl bg-white dark:bg-gray-900 shadow-xl overflow-y-auto border-l border-gray-200 dark:border-gray-700" data-controller="modal">
  <div class="px-6 py-4 flex justify-between items-center border-b border-gray-200 dark:border-gray-700">
    <h2 class="text-lg font-semibold">Issue ID <%= @ticket.unique_id %> Details</h2>
    <button data-action="click->modal#close" class="text-gray-500 hover:text-gray-700 dark:text-gray-300 dark:hover:text-white">
      &times;
    </button>
  </div>

  <div class="px-6 py-4 space-y-4">
    <div class="text-sm text-gray-700 dark:text-gray-300">
      <p class="font-semibold">Created by:
        <span class="font-normal"><%= @ticket.user.name %></span>
      </p>
      <p class="font-semibold">Issue Type:
        <span class="font-normal"><%= @ticket.issue %></span>
      </p>
    </div>

    <div class="rounded overflow-hidden border border-gray-100 dark:border-gray-800">
      <% if @ticket.ticket_image.present? %>
        <%= image_tag @ticket.ticket_image, class: 'w-full object-cover h-48' %>
      <% elsif @project.image.present? %>
        <%= image_tag @project.image, class: 'w-16' %>
      <% else %>
        <%= image_tag 'default.png', class: 'h-16 w-16 object-contain mx-auto my-4' %>
      <% end %>
    </div>

    <div class="grid grid-cols-2 gap-4 text-sm">
      <div>
        <p class="text-gray-500 dark:text-gray-400">Priority</p>
        <p class="inline-block px-3 py-1 text-sm rounded bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200">
          <%= @ticket.priority %>
        </p>
      </div>

      <div>
        <p class="text-gray-500 dark:text-gray-400">Status</p>
        <div>
          <%= render partial: 'ticket_status', locals: { ticket: @ticket } %>
        </div>
      </div>

      <div>
        <p class="text-gray-500 dark:text-gray-400">Product</p>
        <p class="text-gray-800 dark:text-gray-200 font-medium">
          <%= @ticket.software&.name || 'No Software Assigned' %>
        </p>
      </div>

      <div>
        <p class="text-gray-500 dark:text-gray-400">Sub-Product</p>
        <p class="text-gray-800 dark:text-gray-200 font-medium">
          <% if @ticket.software.present? %>
            <% selected_groupware = @ticket.software.groupwares.find_by(id: @ticket.groupware_id) %>
            <%= selected_groupware&.name || 'No Groupware Assigned' %>
          <% end %>
        </p>
      </div>

      <div>
        <p class="text-gray-500 dark:text-gray-400">Time Created</p>
        <p class="text-gray-800 dark:text-gray-200 font-medium">
          <%= @ticket.created_at.strftime("%d %b %Y at %I:%M %p") %>
        </p>
      </div>
    </div>

    <hr class="my-4 border-gray-200 dark:border-gray-700" />

    <div class="space-y-2 text-sm text-gray-800 dark:text-gray-200">
      <p><strong>Target Response Time:</strong> <%= @ticket.initial_response_deadline.strftime("%d %b %Y at %I:%M %p") %></p>
      <p><strong>Target Repair Time:</strong> <%= @ticket.target_repair_deadline.strftime("%d %b %Y at %I:%M %p") %></p>
      <p><strong>Target Resolution Time:</strong> <%= @ticket.resolution_deadline.strftime("%d %b %Y at %I:%M %p") %></p>

      <% if @sla_ticket.present? %>
        <p><strong>Target Response Time SLA Status:</strong> <%= @sla_ticket.sla_status %></p>
        <p><strong>Target Repair Time SLA Status:</strong> <%= @sla_ticket.sla_target_response_deadline %></p>
        <p><strong>Target Resolution Time SLA Status:</strong> <%= @sla_ticket.sla_resolution_deadline %></p>
      <% end %>

      <% if @ticket.due_date.present? %>
        <p>
          <strong>Target Due Date:</strong>
          <%= @ticket.due_date %> (<%= distance_of_time_in_words(DateTime.now, @ticket.due_date) %>)
        </p>
      <% end %>
    </div>
  </div>
</div>

<!-- Blurred Background -->
<div class="fixed inset-0 z-40 bg-black bg-opacity-30 backdrop-blur-sm" data-action="click->modal#close"></div>


<% end %>