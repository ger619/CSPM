<%= turbo_frame_tag "modal" do %>
<div class="fixed inset-0 z-50 overflow-hidden">
  <!-- Blurred background -->
  <div class="absolute inset-0 bg-gray-900 bg-opacity-50 backdrop-blur-sm" data-action="click->turbo-modal#hideModal"></div>
  
  <!-- Modal container -->
  <div class="fixed inset-y-0 right-0 w-full max-w-2xl bg-white shadow-xl overflow-y-auto">
    <div class="p-6">
      <!-- Close button -->
      <button class="absolute top-4 right-4 text-gray-500 hover:text-gray-700" data-action="click->turbo-modal#hideModal">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>

      <!-- SECTION 1: Ticket header -->
      <div class="border-b pb-4 mb-6">
        <h2 class="text-xl font-bold text-gray-800">Issue ID <%= @ticket.unique_id %> Details</h2>
        <div class="flex items-center justify-between mt-2">
          <p class="text-sm text-gray-700">
            <span class="font-medium px-2">Created by: </span> <%= @ticket.user.name %> |
            <span class="font-medium px-2">Issue Type: </span> <%= @ticket.issue %>
          </p>
        </div>
      </div>

      <!-- SECTION 2: Image and Details row -->
      <div class="flex flex-col md:flex-row gap-6 mb-6">
        <!-- Left side - Image -->
        <div class="w-full md:w-1/3">
          <% if @ticket.ticket_image.present? %>
            <%= image_tag @ticket.ticket_image, class: 'w-full h-48 object-contain rounded border border-gray-200 cursor-pointer', data: { action: 'click->image-modal#openModal' } %>
          <% elsif @project.image.present? %>
            <%= image_tag @project.image, class: 'w-full h-48 object-contain rounded border border-gray-200' %>
          <% else %>
            <div class="w-full h-48 bg-gray-100 rounded border border-gray-200 flex items-center justify-center">
              <span class="text-gray-400">No Image</span>
            </div>
          <% end %>
        </div>
        
        <!-- Right side - Details -->
        <div class="w-full md:w-2/3">
          <div class="grid grid-cols-2 gap-4">
            <div>
              <p class="text-sm font-medium text-gray-500 mb-1">Priority</p>
              <p class="font-bold text-gray-800"><%= @ticket.priority %></p>
            </div>
            <div>
              <p class="text-sm font-medium text-gray-500 mb-1">Status</p>
              <div class="font-bold">
                <%= render 'ticket_status' %>
              </div>
            </div>
          </div>
          
          <div class="grid grid-cols-3 gap-4 mt-4">
            <div>
              <p class="text-sm font-medium text-gray-500 mb-1">Product</p>
              <p class="font-medium text-gray-800">
                <% if @ticket.software.present? %>
                  <%= @ticket.software&.name || 'No Software Assigned' %>
                <% end %>
              </p>
            </div>
            
            <div>
              <p class="text-sm font-medium text-gray-500 mb-1">Sub-Product</p>
              <p class="font-medium text-gray-800">
                <% if @ticket.software.present? %>
                  <% selected_groupware = @ticket.software.groupwares.find_by(id: @ticket.groupware_id) %>
                  <%= selected_groupware ? selected_groupware.name : 'No Groupware Assigned' %>
                <% end %>
              </p>
            </div>
            
            <div>
              <p class="text-sm font-medium text-gray-500 mb-1">Time Created</p>
              <p class="font-medium text-gray-800"><%= @ticket.created_at.strftime("%d %b %Y at %I:%M %p") %></p>
            </div>
          </div>
        </div>
      </div>

      <!-- SECTION 3: Target Times -->
      <div class="pt-6 mb-6">
        <h3 class="text-sm font-bold text-gray-700 mb-4">TARGET TIMES</h3>
        <div class="grid grid-cols-3 gap-4 bg-gray-50 p-4 rounded-lg">
          <div>
            <p class="text-xs font-medium text-gray-500 mb-1">Target Response Time</p>
            <p class="text-sm font-medium text-gray-800"><%= @ticket.initial_response_deadline.strftime("%d %b %Y at %I:%M %p") %></p>
          </div>
          <div>
            <p class="text-xs font-medium text-gray-500 mb-1">Target Repair Time</p>
            <p class="text-sm font-medium text-gray-800"><%= @ticket.target_repair_deadline.strftime("%d %b %Y at %I:%M %p") %></p>
          </div>
          <div>
            <p class="text-xs font-medium text-gray-500 mb-1">Target Resolution Time</p>
            <p class="text-sm font-medium text-gray-800"><%= @ticket.resolution_deadline.strftime("%d %b %Y at %I:%M %p") %></p>
          </div>
        </div>
      </div>

      <!-- SECTION 4: SLA Status -->
      <div class="pt-6">
        <h3 class="text-sm font-bold text-gray-700 mb-4">SLA STATUS</h3>
        <div class="grid grid-cols-4 gap-4 bg-gray-50 p-4 rounded-lg">
          <div>
            <p class="text-xs font-medium text-gray-500 mb-1">SLA Status</p>
            <p class="text-sm font-medium text-green-600">
              <% if @sla_ticket.present? %>
                <%= @sla_ticket.sla_status %>
              <% else %>
                Not Available
              <% end %>
            </p>
          </div>
          <div>
            <p class="text-xs font-medium text-gray-500 mb-1">Target Resolution Time</p>
            <p class="text-sm font-medium text-green-600">
              <% if @sla_ticket.present? %>
                <%= @sla_ticket.sla_resolution_deadline %>
              <% else %>
                Not Available
              <% end %>
            </p>
          </div>
          <div>
            <p class="text-xs font-medium text-gray-500 mb-1">Target Repair Time</p>
            <p class="text-sm font-medium text-green-600">
              <% if @sla_ticket.present? %>
                <%= @sla_ticket.sla_target_response_deadline %>
              <% else %>
                Not Available
              <% end %>
            </p>
          </div>
          <div>
            <p class="text-xs font-medium text-gray-500 mb-1">Target Response Time</p>
            <p class="text-sm font-medium text-green-600">
              <% if @sla_ticket.present? %>
                <%= @sla_ticket.sla_status %>
              <% else %>
                Not Available
              <% end %>
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Image modal (keep this the same as before) -->
<div id="imageModal" class="modal hidden fixed inset-0 z-50 overflow-auto bg-black bg-opacity-75" data-controller="image-modal" data-image-modal-target="modal">
  <span class="close absolute top-4 right-4 text-white text-3xl cursor-pointer" data-action="click->image-modal#closeModal" data-image-modal-target="closeButton">&times;</span>
  <img class="modal-content block max-w-full max-h-screen m-auto" id="fullImage" data-image-modal-target="modalImage" alt='show image'>
</div>
<% end %>