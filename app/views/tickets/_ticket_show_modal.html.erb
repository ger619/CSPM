<%= turbo_frame_tag "modal" do %>
<div class="fixed inset-0 z-50 overflow-hidden" data-controller="modal">
  <!-- Blurred background -->
  <div class="absolute inset-0 bg-gray-900 bg-opacity-50 backdrop-blur-sm transition-opacity duration-300"></div>
  
  <!-- Modal container - now using flex for two columns -->
  <div class="fixed inset-y-0 right-0 w-full max-w-6xl flex overflow-hidden">
    <!-- Left panel (ticket details) -->
    <div class="w-1/2 bg-white dark:bg-gray-800 shadow-xl overflow-y-auto">
      <div class="p-6">
        <!-- Close button -->
        <button class="absolute top-4 right-4 text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-200" 
                data-action="click->modal#close">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>

        <!-- SECTION 1: Ticket header -->
        <div class="border-b border-gray-200 dark:border-gray-700 pb-4 mb-6">
          <h2 class="text-xl font-bold text-gray-900 dark:text-white">Issue ID <%= @ticket.unique_id %> Details</h2>
          <div class="flex items-center justify-between mt-2">
            <p class="text-sm text-gray-600 dark:text-gray-300">
              <span class="font-medium">Created by: </span> <%= @ticket.user.name %> |
              <span class="font-medium">Issue Type: </span> <%= @ticket.issue %>
            </p>
          </div>
        </div>

        <!-- SECTION 2: Image and Details row -->
        <div class="flex flex-col md:flex-row gap-6 mb-6">
          <!-- Left side - Image -->
          <div class="w-full md:w-1/3">
            <% if @ticket.ticket_image.present? %>
              <%= image_tag @ticket.ticket_image, class: 'w-full h-48 object-contain rounded border border-gray-200 dark:border-gray-600 cursor-pointer', data: { action: 'click->image-modal#openModal' } %>
            <% elsif @project.image.present? %>
              <%= image_tag @project.image, class: 'w-full h-48 object-contain rounded border border-gray-200 dark:border-gray-600' %>
            <% else %>
              <div class="w-full h-48 bg-gray-100 dark:bg-gray-700 rounded border border-gray-200 dark:border-gray-600 flex items-center justify-center">
                <span class="text-gray-400 dark:text-gray-500">No Image</span>
              </div>
            <% end %>
          </div>
          
          <!-- Right side - Details -->
          <div class="w-full md:w-2/3">
            <div class="grid grid-cols-2 gap-4">
              <div>
                <p class="text-sm font-medium text-gray-600 dark:text-gray-300 mb-1">Priority</p>
                <p class="font-bold text-gray-900 dark:text-white"><%= @ticket.priority %></p>
              </div>
              <div>
                <p class="text-sm font-medium text-gray-600 dark:text-gray-300 mb-1">Status</p>
                
                <div class="font-bold flex items-center relative group" data-controller="status-modal">
                  <!-- Clickable Status with Edit Icon -->
                  <button type="button"
                          class="flex items-center gap-2 px-3 py-1.5 rounded-lg transition-all hover:bg-blue-50 dark:hover:bg-blue-900/30 focus:outline-none focus:ring-2 focus:ring-blue-500 dark:focus:ring-blue-400 focus:ring-offset-2 dark:focus:ring-offset-gray-800"
                          data-action="click->status-modal#toggleDropdown">
                    <span class="text-gray-800 dark:text-gray-200 group-hover:text-blue-700 dark:group-hover:text-blue-400">
                      <%= render 'ticket_status' %>
                    </span>
                    <svg xmlns="http://www.w3.org/2000/svg" 
                        class="h-5 w-5 text-gray-400 dark:text-gray-500 group-hover:text-blue-500 dark:group-hover:text-blue-400 transition-colors" 
                        fill="none" 
                        viewBox="0 0 24 24" 
                        stroke="currentColor"
                        stroke-width="1.5">
                      <path stroke-linecap="round" 
                            stroke-linejoin="round" 
                            d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L6.832 19.82a4.5 4.5 0 01-1.897 1.13l-2.685.8.8-2.685a4.5 4.5 0 011.13-1.897L16.863 4.487zm0 0L19.5 7.125" />
                    </svg>
                  </button>

                  <!-- Status Change Modal -->
                  <div class="hidden bg-white dark:bg-gray-800 absolute z-50 mt-2 w-80 rounded-xl shadow-xl ring-1 ring-gray-200/80 dark:ring-gray-700/80 overflow-hidden"
                      data-status-modal-target="dropdown">
                    <!-- Modal Header -->
                    <div class="px-5 py-4 border-b border-gray-100 dark:border-gray-700">
                      <h3 class="font-semibold flex items-center justify-between text-gray-900 dark:text-white">
                        <span>Update Ticket Status</span>
                        <button type="button"
                                class="text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-200"
                                data-action="click->status-modal#closeDropdown"
                                aria-label="Close">
                          <svg xmlns="http://www.w3.org/2000/svg"
                              class="h-5 w-5"
                              fill="none"
                              viewBox="0 0 24 24"
                              stroke="currentColor"
                              stroke-width="1.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                          </svg>
                        </button>
                      </h3>
                    </div>
                    
                    <!-- Modal Content -->
                    <div class="p-5">
                      <%= render 'tickets/ticket_action', project: @project, ticket: @ticket %>
                    </div>
                    
                    <!-- Modal Footer -->
                    <div class="px-5 py-3 border-t border-gray-100 dark:border-gray-700 flex justify-end">
                      <button type="button"
                              class="px-4 py-2 text-sm text-red-600 hover:text-red-800 dark:text-red-400 dark:hover:text-red-300 font-medium rounded-md transition-colors"
                              data-action="click->status-modal#closeDropdown">
                        Cancel
                      </button>
                    </div>
                  </div>
                </div>
              </div>
            </div>
            
            <div class="grid grid-cols-3 gap-4 mt-4">
              <div>
                <p class="text-sm font-medium text-gray-600 dark:text-gray-300 mb-1">Product</p>
                <p class="font-medium text-gray-900 dark:text-white">
                  <% if @ticket.software.present? %>
                    <%= @ticket.software&.name || 'No Software Assigned' %>
                  <% end %>
                </p>
              </div>
              
              <div>
                <p class="text-sm font-medium text-gray-600 dark:text-gray-300 mb-1">Sub-Product</p>
                <p class="font-medium text-gray-900 dark:text-white">
                  <% if @ticket.software.present? %>
                    <% selected_groupware = @ticket.software.groupwares.find_by(id: @ticket.groupware_id) %>
                    <%= selected_groupware ? selected_groupware.name : 'No Groupware Assigned' %>
                  <% end %>
                </p>
              </div>
              
              <div>
                <p class="text-sm font-medium text-gray-600 dark:text-gray-300 mb-1">Time Created</p>
                <p class="font-medium text-gray-900 dark:text-white"><%= @ticket.created_at.strftime("%d %b %Y at %I:%M %p") %></p>
              </div>
            </div>
          </div>
        </div>

        <!-- SECTION 3: Target Times -->
        <div class="pt-6 mb-2">
          <h3 class="text-sm font-bold text-gray-900 dark:text-white mb-2">TARGET TIMES</h3>
          <div class="grid grid-cols-3 gap-4 p-2 rounded-lg bg-gray-50 dark:bg-gray-700">
            <div>
              <p class="text-xs font-medium text-gray-600 dark:text-gray-300 mb-1">Target Response Time</p>
              <p class="text-sm font-medium text-gray-900 dark:text-white"><%= @ticket.initial_response_deadline.strftime("%d %b %Y at %I:%M %p") %></p>
            </div>
            <div>
              <p class="text-xs font-medium text-gray-600 dark:text-gray-300 mb-1">Target Repair Time</p>
              <p class="text-sm font-medium text-gray-900 dark:text-white"><%= @ticket.target_repair_deadline.strftime("%d %b %Y at %I:%M %p") %></p>
            </div>
            <div>
              <p class="text-xs font-medium text-gray-600 dark:text-gray-300 mb-1">Target Resolution Time</p>
              <p class="text-sm font-medium text-gray-900 dark:text-white"><%= @ticket.resolution_deadline.strftime("%d %b %Y at %I:%M %p") %></p>
            </div>
          </div>
        </div>

        <!-- SECTION 4: SLA Status -->
        <div class="pt-2">
          <h3 class="text-sm font-bold text-gray-900 dark:text-white mb-2">SLA STATUS</h3>
          <div class="grid grid-cols-4 gap-4 p-2 rounded-lg bg-gray-50 dark:bg-gray-700">
            <div>
              <p class="text-xs font-medium text-gray-600 dark:text-gray-300 mb-1">SLA Status</p>
              <p class="text-sm font-medium text-green-600 dark:text-green-400">
                <% if @sla_ticket.present? %>
                  <%= @sla_ticket.sla_status %>
                <% else %>
                  Not Available
                <% end %>
              </p>
            </div>
            <div>
              <p class="text-xs font-medium text-gray-600 dark:text-gray-300 mb-1">Target Resolution Time</p>
              <p class="text-sm font-medium text-green-600 dark:text-green-400">
                <% if @sla_ticket.present? %>
                  <%= @sla_ticket.sla_resolution_deadline %>
                <% else %>
                  Not Available
                <% end %>
              </p>
            </div>
            <div>
              <p class="text-xs font-medium text-gray-600 dark:text-gray-300 mb-1">Target Repair Time</p>
              <p class="text-sm font-medium text-green-600 dark:text-green-400">
                <% if @sla_ticket.present? %>
                  <%= @sla_ticket.sla_target_response_deadline %>
                <% else %>
                  Not Available
                <% end %>
              </p>
            </div>
            <div>
              <p class="text-xs font-medium text-gray-600 dark:text-gray-300 mb-1">Target Response Time</p>
              <p class="text-sm font-medium text-green-600 dark:text-green-400">
                <% if @sla_ticket.present? %>
                  <%= @sla_ticket.sla_status %>
                <% else %>
                  Not Available
                <% end %>
              </p>
            </div>
          </div>
        </div>

        <!-- Subject and Content -->
        <div class="col-span-2 mt-6">
          <div class="mb-4">
            <div class="text-sm font-semibold text-gray-600 dark:text-gray-300 uppercase tracking-wider mb-1">Subject</div>
            <div class="mt-1 text-base font-medium text-gray-900 dark:text-white">
              <%= @ticket.subject %>
            </div>
          </div>

          <div class="mb-4">
            <div class="text-sm font-semibold text-gray-600 dark:text-gray-300 uppercase tracking-wider mb-1">Content</div>
            <div class="mt-1 text-base text-gray-700 dark:text-gray-300 whitespace-pre-wrap">
              <% if @ticket.content.present? %>
                <%= sanitize raw(@ticket.content.to_trix_html.gsub(/\[.*?\]/, '').strip) %>
              <% end %>
            </div>
          </div>
        </div>

        <!-- Assigned Users -->
        <div class="mt-6">
          <%= render 'tickets/assign_people_tickets' %>
        </div>

        <!-- Due Date, Severity, Issue Type -->
        <div class="mt-6">
          <%= render 'tickets/custom_field' %>
        </div>
      </div>
    </div>

    <!-- Right panel (messaging) -->
    <div class="w-1/2 bg-gray-50 dark:bg-gray-700 border-l border-gray-200 dark:border-gray-600 flex flex-col">
      <!-- Messages header -->
      <div class="p-4 border-b border-gray-200 dark:border-gray-600">
        <h3 class="font-bold text-gray-900 dark:text-white">Messages</h3>
      </div>

      <!-- Messages content -->
      <div class="flex-1 overflow-y-auto p-4 space-y-4" id="messages">
        <%= render 'issues/issues_table' %>
      </div>

      <!-- New message form (hidden by default) -->
      <div id="newMessageForm" class="hidden p-4 border-t border-gray-200 dark:border-gray-600">
        <%= render 'issues/form', project: @project, ticket: @ticket %>
      </div>

      <!-- New message button -->
      <% unless @ticket.statuses.first&.name == 'Closed' %>
        <div class="p-4 border-t border-gray-200 dark:border-gray-600">
          <button id="newMessageButton" 
                  class="flex items-center justify-center gap-2 w-full px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white rounded-md transition-colors"
                  data-action="click->messages#toggleForm">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-11a1 1 0 10-2 0v2H7a1 1 0 100 2h2v2a1 1 0 102 0v-2h2a1 1 0 100-2h-2V7z" clip-rule="evenodd" />
            </svg>
            New Message
          </button>
        </div>
      <% end %>
    </div>
  </div>
</div>

<!-- Image modal -->
<div id="imageModal" class="modal hidden fixed inset-0 z-50 overflow-auto bg-opacity-75" data-controller="image-modal" data-image-modal-target="modal">
  <span class="close absolute top-4 right-4 text-3xl cursor-pointer" data-action="click->image-modal#closeModal" data-image-modal-target="closeButton">&times;</span>
  <img class="modal-content block max-w-full max-h-screen m-auto" id="fullImage" data-image-modal-target="modalImage" alt='show image'>
</div>
<% end %>