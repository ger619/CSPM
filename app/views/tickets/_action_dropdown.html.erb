<td class="px-4 py-4 whitespace-nowrap text-right text-sm font-medium" data-controller="dropdown" data-dropdown-ticket-id-value="<%= ticket.id %>">
  <div class="relative inline-block text-left">
    <div>
      <button
        type="button"
        class="inline-flex justify-center rounded-lg hover:bg-gray-100 dark:hover:bg-gray-700 focus:outline-none"
        id="menu-button-<%= ticket.id %>"
        aria-expanded="false"
        aria-haspopup="true"
        data-action="click->dropdown#toggle">
        <svg class="w-5 h-5"
             xmlns="http://www.w3.org/2000/svg"
             viewBox="0 0 20 20"
             fill="currentColor">
          <path d="M10 6a2 2 0 110-4 2 2 0 010 4zM10 12a2 2 0 110-4 2 2 0 010 4zM10 18a2 2 0 110-4 2 2 0 010 4z" />
        </svg>
      </button>
    </div>

    <div id="dropdown-<%= ticket.id %>"
         data-dropdown-target="menu"
         class="hidden p-4 flex justify-center origin-top-right absolute bg-white dark:bg-gray-600 right-0 mt-2 rounded-md shadow-lg focus:outline-none z-10">
      <div class="py-1" role="none">
        <div class="flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg"
               fill="none"
               viewBox="0 0 24 24"
               stroke-width="1.5"
               stroke="currentColor"
               class="h-5 w-5">
            <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
          </svg>

          <%= link_to 'View',
                      project_ticket_path(ticket.project, ticket),
                      class: 'text-sm hover:text-blue-600 hover:underline' %>
        </div>

        <div class="flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg"
               fill="none"
               viewBox="0 0 24 24"
               stroke-width="1.5"
               stroke="currentColor"
               class="h-5 w-5">
            <path stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M15.75 10.5L12 14.25l-3.75-3.75" />
          </svg>

          <%= link_to 'Quick View',
                      modal_show_project_ticket_path(ticket.project, ticket),
                      data: { turbo_frame: "modal" },
                      controller: "modal",
                      action: "modal#close",
                      class: 'text-sm hover:text-blue-600 hover:underline' %>
        </div>

        <% if can?(:edit, ticket) %>
          <div class="flex items-center py-4 gap-2">
            <svg xmlns="http://www.w3.org/2000/svg"
                 fill="none"
                 viewBox="0 0 24 24"
                 stroke-width="1.5"
                 stroke="currentColor"
                 class="h-5 w-5">
              <path stroke-linecap="round"
                    stroke-linejoin="round"
                    d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L6.832 19.82a4.5 4.5 0 0 1-1.897 1.13l-2.685.8.8-2.685a4.5 4.5 0 0 1 1.13-1.897L16.863 4.487Zm0 0L19.5 7.125" />
            </svg>

            <%= link_to 'Edit',
                        edit_project_ticket_path(ticket.project, ticket),
                        class: 'text-sm hover:text-blue-600 hover:underline' %>
          </div>
        <% end %>

        <% if can?(:destroy, ticket) %>
          <div class="flex items-center gap-2 text-red-600">
            <svg xmlns="http://www.w3.org/2000/svg"
                 fill="none"
                 viewBox="0 0 24 24"
                 stroke-width="1.5"
                 stroke="currentColor"
                 class="h-5 w-5">
              <path stroke-linecap="round"
                    stroke-linejoin="round"
                    d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
            </svg>

            <%= button_to 'Delete',
                          [ticket.project, ticket],
                          method: :delete,
                          data: { turbo_confirm: 'Are you sure?' },
                          class: 'text-sm text-red-600 hover:text-red-800 hover:underline' %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</td>