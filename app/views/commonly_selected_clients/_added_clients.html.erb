<h3 class="text-lg font-semibold mb-2">Your Common Clients</h3>
<% if @common_clients.any? %>
  <div class="flex flex-wrap gap-2">
    <% @common_clients.each do |client| %>
      <span class="px-3 py-1 rounded-full bg-blue-100 text-blue-800"><%= client.name %></span>
    <% end %>
  </div>
<% else %>
  <p class="text-gray-500">You have not selected any common clients yet.</p>
<% end %>
