<h3 class="font-semibold text-lg text-gray-800 dark:text-gray-200 mb-3">Your Common Clients</h3>
<div class="flex flex-wrap gap-2 items-center">
  <% if current_user.common_clients.any? %>
    <% current_user.common_clients.each do |client| %>
      <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-200">
        <%= client.name %>
      </span>
    <% end %>
  <% else %>
    <p class="text-gray-600 dark:text-gray-300">No commonly selected clients yet.</p>
  <% end %>
</div>