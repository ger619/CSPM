<%= turbo_frame_tag "modal" do %>
  <div class="fixed inset-0 bg-black bg-opacity-50 flex justify-center items-center z-50">
    <div class="bg-white dark:bg-gray-800 p-6 rounded-lg shadow-xl w-full max-w-2xl relative">
      
      <% if flash.now[:notice] %>
        <div class="text-green-600"><%= flash.now[:notice] %></div>
      <% elsif flash.now[:alert] %>
        <div class="text-red-600"><%= flash.now[:alert] %></div>
      <% end %>

      <!-- CLOSE BUTTON -->
      <%= link_to "×", "#", data: { controller: "modal", action: "modal#close" }, class: "absolute top-3 right-3" %>

      <!-- HEADER -->
      <h2 class="text-2xl font-bold mb-4">Manage Common Clients</h2>

      <!-- Common Clients -->
      <%= render partial: "commonly_selected_clients/added_clients" %>

      <!-- Add & Remove Sections -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-6">
        <%= render partial: "commonly_selected_clients/add_client" %>
        <%= render partial: "commonly_selected_clients/remove_client" %>
      </div>

      <!-- Close Button -->
      <div class="flex justify-end mt-6">
        <%= link_to "Close", "#", data: { controller: "modal", action: "modal#close" }, class: "bg-red-600 text-white px-4 py-2 rounded" %>
      </div>
    </div>
  </div>
<% end %>
