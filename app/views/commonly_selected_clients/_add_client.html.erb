<%= form_with url: commonly_selected_clients_path, method: :post do |f| %>
  <div>
    <%= label_tag :client_id, "Select Client" %>
    <%= select_tag :client_id,
        options_from_collection_for_select(@available_clients, :id, :name),
        include_blank: "Select client...",
        required: true,
        class: "w-full border p-2" %>
  </div>
  <div class="mt-2">
    <%= submit_tag "Add Client", class: "bg-blue-600 text-white px-4 py-2 rounded" %>
  </div>
<% end %>
